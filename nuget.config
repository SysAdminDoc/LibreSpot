<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Clear inherited sources so only explicitly listed feeds are used. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <!-- Map all packages to nuget.org — an unmapped package will fail restore. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
