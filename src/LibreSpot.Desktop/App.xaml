<Application x:Class="LibreSpot.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LibreSpot.Desktop.Converters"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Themes/Palette.xaml" />
        <ResourceDictionary Source="Themes/Controls.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <conv:PrettifyConverter x:Key="PrettifyConverter" />
      <conv:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
