                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasWarningHealthIssues}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasCriticalHealthIssues}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding ShellReadinessDetail}"
