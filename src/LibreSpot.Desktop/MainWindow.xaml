<Window x:Class="LibreSpot.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:LibreSpot.Desktop.Controls"
        xmlns:avalon="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
        xmlns:models="clr-namespace:LibreSpot.Desktop.Models"
        xmlns:viewModels="clr-namespace:LibreSpot.Desktop.ViewModels"
        xmlns:props="clr-namespace:LibreSpot.Desktop.Properties"
        xmlns:services="clr-namespace:LibreSpot.Desktop.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        mc:Ignorable="d"
        Title="{services:Loc AppTitle}"
        Width="1500"
        Height="940"
        MinWidth="1360"
        MinHeight="820"
        Icon="pack://application:,,,/Assets/LibreSpot.ico"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource CanvasBrush}"
        WindowStyle="None"
        ResizeMode="CanResize"
        Style="{StaticResource WindowChromeStyle}">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        ResizeBorderThickness="6"
                        CornerRadius="0"
                        GlassFrameThickness="0"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>

  <Window.InputBindings>
    <KeyBinding Key="Escape" Command="{Binding EscapeCommand}" />
    <KeyBinding Key="F5" Command="{Binding RefreshSnapshotCommand}" />
  </Window.InputBindings>

  <Window.TaskbarItemInfo>
    <!-- Mirror run state onto the taskbar icon so users see progress at a glance
         even when LibreSpot is minimized during a patch run. -->
    <TaskbarItemInfo ProgressState="{Binding TaskbarProgressState}"
                     ProgressValue="{Binding TaskbarProgressFraction}">
      <TaskbarItemInfo.ThumbButtonInfos>
        <ThumbButtonInfo Description="{services:Loc ModeRecommendedDescription}"
                         Command="{Binding ShowRecommendedWorkspaceCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
        <ThumbButtonInfo Description="{services:Loc Ui_CustomSettings}"
                         Command="{Binding ShowCustomWorkspaceCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
        <ThumbButtonInfo Description="{services:Loc ModeMaintenanceTitle}"
                         Command="{Binding ShowMaintenanceWorkspaceCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
        <ThumbButtonInfo Description="{services:Loc Ui_ImportProfile}"
                         Command="{Binding ImportProfileCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
        <ThumbButtonInfo Description="{services:Loc ButtonOpenLibreSpotFolder}"
                         Command="{Binding OpenLibreSpotFolderCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
      </TaskbarItemInfo.ThumbButtonInfos>
    </TaskbarItemInfo>
  </Window.TaskbarItemInfo>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <Style x:Key="StatusMarkerStyle" TargetType="Border">
      <Setter Property="Width" Value="4" />
      <Setter Property="Height" Value="14" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="Margin" Value="0,2,10,0" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="MinimalSectionStyle" TargetType="Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="0,0,0,18" />
      <Setter Property="Margin" Value="0,0,0,18" />
    </Style>

    <DataTemplate DataType="{x:Type viewModels:HealthIssueActionViewModel}" x:Key="HealthIssueActionTemplate">
      <Button Content="{Binding ButtonText}"
              Command="{Binding Command}"
              ToolTip="{Binding Description}"
              AutomationProperties.Name="{Binding ButtonText}"
              AutomationProperties.HelpText="{Binding Description}"
              MinWidth="0"
              Height="34"
              Padding="12,0"
              Margin="0,0,8,8">
        <Button.Style>
          <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="FontSize" Value="12" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Button.Style>
      </Button>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:HealthIssueViewModel}" x:Key="HealthIssueTemplate">
      <Border Margin="0,0,0,8">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding Severity}" Value="critical">
                <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding Severity}" Value="warning">
                <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Name}"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="12.5"
                       TextWrapping="Wrap"
                       Margin="0,0,10,0" />
            <TextBlock Grid.Column="1"
                       Text="{Binding Status}"
                       TextAlignment="Right">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                  <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Severity}" Value="critical">
                      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Severity}" Value="warning">
                      <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>
          <TextBlock Text="{Binding Evidence}"
                     Style="{StaticResource CaptionTextStyle}"
                     Margin="0,6,0,0" />
          <ItemsControl ItemsSource="{Binding Actions}"
                        ItemTemplate="{StaticResource HealthIssueActionTemplate}"
                        Margin="0,10,0,0"
                        Visibility="{Binding HasActions, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
          <TextBlock Text="{Binding RecommendedActionText}"
                     Style="{StaticResource CaptionTextStyle}"
                     Foreground="{DynamicResource MutedTextBrush}"
                     Margin="0,6,0,0"
                     Visibility="{Binding ShowRecommendedActionText, Converter={StaticResource BoolToVisibilityConverter}}" />
          <TextBlock Text="{Binding Path}"
                     Style="{StaticResource CaptionTextStyle}"
                     Foreground="{DynamicResource SubtleTextBrush}"
                     Margin="0,6,0,0"
                     Visibility="{Binding HasPath, Converter={StaticResource BoolToVisibilityConverter}}" />
          <TextBlock Text="{Binding LastChangedDisplay}"
                     Style="{StaticResource CaptionTextStyle}"
                     Foreground="{DynamicResource SubtleTextBrush}"
                     Margin="0,4,0,0"
                     Visibility="{Binding HasLastChanged, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:OptionToggleViewModel}" x:Key="OptionTemplate">
      <CheckBox Style="{StaticResource SettingCheckBoxStyle}"
                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                AutomationProperties.Name="{Binding Title}"
                AutomationProperties.HelpText="{Binding Description}"
                ToolTip="{Binding Description}"
                Margin="0,0,10,10">
        <StackPanel>
          <TextBlock Text="{Binding Title}"
                     Foreground="{DynamicResource TextBrush}"
                     FontWeight="SemiBold"
                     FontSize="13.5"
                     LineHeight="18"
                     TextWrapping="Wrap" />
          <Border MinWidth="86"
                  HorizontalAlignment="Left"
                  Margin="0,7,0,8">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                      <Setter Property="Background" Value="{DynamicResource AccentMistBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
                    </DataTrigger>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource MicroBadgeTextStyle}">
                    <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusOptional}" />
                    <Style.Triggers>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusRecommended}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="False" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusAdded}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusRemoved}" />
                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
          </Border>
          <TextBlock Text="{Binding Description}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </CheckBox>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:ExtensionToggleViewModel}" x:Key="ExtensionTemplate">
      <CheckBox Style="{StaticResource SettingCheckBoxStyle}"
                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                AutomationProperties.Name="{Binding Title}"
                AutomationProperties.HelpText="{Binding Description}"
                ToolTip="{Binding Description}"
                Margin="0,0,10,10">
        <StackPanel>
          <TextBlock Text="{Binding Title}"
                     Foreground="{DynamicResource TextBrush}"
                     FontWeight="SemiBold"
                     FontSize="13.5"
                     LineHeight="18"
                     TextWrapping="Wrap" />
          <Border MinWidth="76"
                  HorizontalAlignment="Left"
                  Margin="0,7,0,8">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                      <Setter Property="Background" Value="{DynamicResource AccentMistBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
                    </DataTrigger>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource MicroBadgeTextStyle}">
                    <Setter Property="Text" Value="{x:Static props:Strings.ExtensionStatusAvailable}" />
                    <Style.Triggers>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.ExtensionStatusDefault}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="False" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusAdded}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusRemoved}" />
                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
          </Border>
          <TextBlock Text="{Binding Description}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </CheckBox>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:LocalProfileCardViewModel}" x:Key="LocalProfileTemplate">
      <Border Margin="0,0,0,8">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
            <Style.Triggers>
              <!-- Hover affordance for the clickable card. Listed first so the
                   active/selected accent border always overrides it. -->
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}" />
              </Trigger>
              <DataTrigger Binding="{Binding IsActive}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Background" Value="{DynamicResource AccentMistBrush}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Width="4"
                  CornerRadius="2"
                  Margin="0,2,12,0"
                  VerticalAlignment="Stretch">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding StateTone}" Value="active">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding StateTone}" Value="template">
                    <Setter Property="Background" Value="{DynamicResource InfoBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
          </Border>
          <StackPanel Grid.Column="1">
            <TextBlock Text="{Binding Name}"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="13.5"
                       TextWrapping="Wrap"
                       LineHeight="18" />
            <WrapPanel Margin="0,7,0,0">
              <Border Margin="0,0,6,6">
                <Border.Style>
                  <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource AccentMistBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Text="{Binding StateBadge}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
              <Border Margin="0,0,6,6">
                <Border.Style>
                  <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Text="{Binding KindBadge}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
              <Border Margin="0,0,6,6"
                      Style="{StaticResource MicroBadgeStyle}">
                <TextBlock Text="{Binding CapabilityText}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
            </WrapPanel>
            <TextBlock Text="{Binding Description}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,2,0,0"
                       TextTrimming="CharacterEllipsis"
                       Visibility="{Binding HasDescription, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock Text="{Binding UpdatedText}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       Margin="0,6,0,0" />
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:MaintenanceActionCardViewModel}" x:Key="MaintenanceTemplate">
      <Border Margin="0,0,0,12"
              Visibility="{Binding IsRelevant, Converter={StaticResource BoolToVisibilityConverter}}">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
            <Setter Property="Padding" Value="16" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Margin="0,0,18,0">
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="14"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding Description}"
                       Style="{StaticResource BodyTextStyle}"
                       Margin="0,6,0,0" />
            <TextBlock Margin="0,10,0,0">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                  <Setter Property="Text" Value="{x:Static props:Strings.MaintenanceCardDefaultDetail}" />
                  <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                      <Setter Property="Text" Value="{x:Static props:Strings.MaintenanceCardDestructiveDetail}" />
                      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>

          <Button Grid.Column="1"
                  MinWidth="150"
                  Height="42"
                  Padding="16,0"
                  Content="{Binding ButtonText}"
                  AutomationProperties.AutomationId="{Binding AutomationId}"
                  AutomationProperties.Name="{Binding ButtonText}"
                  AutomationProperties.HelpText="{Binding Description}"
                  Command="{Binding Command}">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:SupportBundleCategoryViewModel}" x:Key="SupportBundleCategoryTemplate">
      <CheckBox Style="{StaticResource SettingCheckBoxStyle}"
                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                AutomationProperties.Name="{Binding Title}"
                AutomationProperties.HelpText="{Binding Detail}"
                ToolTip="{Binding Detail}"
                Margin="0,0,10,10">
        <StackPanel>
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,0,10,0" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <Border Style="{StaticResource MicroBadgeStyle}" Margin="0,0,6,0">
                <TextBlock Text="{Binding FileCountText}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
              <Border Style="{StaticResource MicroBadgeStyle}">
                <TextBlock Text="{Binding EstimatedSizeText}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
            </StackPanel>
          </Grid>
          <TextBlock Text="{Binding Detail}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </CheckBox>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:SelectionInsightViewModel}" x:Key="SelectionInsightTemplate">
      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Width="4"
                Height="14"
                CornerRadius="2"
                Margin="0,3,10,0"
                VerticalAlignment="Top">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding Tone}" Value="accent">
                  <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="warning">
                  <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
        </Border>
        <StackPanel Grid.Column="1">
          <TextBlock Text="{Binding Title}"
                     FontWeight="SemiBold"
                     FontSize="12.5"
                     Margin="0,0,0,4">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Tone}" Value="accent">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Tone}" Value="warning">
                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <TextBlock Text="{Binding Detail}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="SelectionBadgeTemplate">
      <Border Style="{StaticResource MicroBadgeStyle}"
              Background="{DynamicResource Surface3Brush}"
              BorderBrush="{DynamicResource StrokeBrush}"
              Margin="0,0,8,8">
        <TextBlock Text="{Binding}"
                   Style="{StaticResource MicroBadgeTextStyle}"
                   Foreground="{DynamicResource TextBrush}" />
      </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:StatusDashboardItemViewModel}" x:Key="StatusDashboardItemTemplate">
      <Border Style="{StaticResource SubtleCardStyle}"
              Margin="0,0,10,10"
              AutomationProperties.Name="{Binding Label}"
              AutomationProperties.HelpText="{Binding Detail}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Width="4"
                  CornerRadius="2"
                  Margin="0,2,12,0"
                  VerticalAlignment="Stretch">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Tone}" Value="{x:Static models:HealthSeverity.Ready}">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Tone}" Value="{x:Static models:HealthSeverity.Warning}">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Tone}" Value="{x:Static models:HealthSeverity.Critical}">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                  </DataTrigger>
                </Style.Triggers>
