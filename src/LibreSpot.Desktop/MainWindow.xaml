                    <Style TargetType="Path">
                      <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasWarningHealthIssues}" Value="True">
                          <Setter Property="Stroke" Value="{DynamicResource WarningBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasCriticalHealthIssues}" Value="True">
                          <Setter Property="Stroke" Value="{DynamicResource DangerBrush}" />
