<Window x:Class="LibreSpot.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:LibreSpot.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="LibreSpot"
        Width="1440"
        Height="920"
        MinWidth="1200"
        MinHeight="820"
        Icon="pack://application:,,,/Assets/LibreSpot.ico"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource CanvasBrush}"
        Style="{StaticResource WindowChromeStyle}">
  <Window.InputBindings>
    <KeyBinding Key="Escape" Command="{Binding EscapeCommand}" />
    <KeyBinding Key="F5" Command="{Binding RefreshSnapshotCommand}" />
  </Window.InputBindings>

  <Window.TaskbarItemInfo>
    <!-- Mirror run state onto the taskbar icon so users see progress at a glance
         even when LibreSpot is minimized during a patch run. -->
    <TaskbarItemInfo ProgressState="{Binding TaskbarProgressState}"
                     ProgressValue="{Binding TaskbarProgressFraction}" />
  </Window.TaskbarItemInfo>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <Style x:Key="StatusMarkerStyle" TargetType="Border">
      <Setter Property="Width" Value="4" />
      <Setter Property="Height" Value="14" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Background" Value="{StaticResource StrokeBrush}" />
      <Setter Property="Margin" Value="0,2,10,0" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="MinimalSectionStyle" TargetType="Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeSoftBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="0,0,0,18" />
      <Setter Property="Margin" Value="0,0,0,18" />
    </Style>

    <DataTemplate DataType="{x:Type viewModels:OptionToggleViewModel}" x:Key="OptionTemplate">
      <CheckBox Style="{StaticResource SettingCheckBoxStyle}"
                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                AutomationProperties.Name="{Binding Title}"
                AutomationProperties.HelpText="{Binding Description}"
                ToolTip="{Binding Description}"
                Margin="0,0,10,10">
        <StackPanel>
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Title}"
                       Foreground="{StaticResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,0,10,0" />
            <Border Grid.Column="1"
                    MinWidth="86">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                  <Style.Triggers>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{StaticResource AccentMistBrush}" />
                      <Setter Property="BorderBrush" Value="{StaticResource AccentRingBrush}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="False" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{StaticResource AccentMistBrush}" />
                      <Setter Property="BorderBrush" Value="{StaticResource AccentRingBrush}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                      <Setter Property="BorderBrush" Value="{StaticResource WarningRingBrush}" />
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource MicroBadgeTextStyle}">
                    <Setter Property="Text" Value="Optional" />
                    <Style.Triggers>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="Recommended" />
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="False" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="Added" />
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="Removed" />
                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Border>
          </Grid>
          <TextBlock Text="{Binding Description}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </CheckBox>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:ExtensionToggleViewModel}" x:Key="ExtensionTemplate">
      <CheckBox Style="{StaticResource SettingCheckBoxStyle}"
                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                AutomationProperties.Name="{Binding Title}"
                AutomationProperties.HelpText="{Binding Description}"
                ToolTip="{Binding Description}"
                Margin="0,0,10,10">
        <StackPanel>
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Title}"
                       Foreground="{StaticResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,0,10,0" />
            <Border Grid.Column="1"
                    MinWidth="76">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                  <Style.Triggers>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{StaticResource AccentMistBrush}" />
                      <Setter Property="BorderBrush" Value="{StaticResource AccentRingBrush}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="False" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{StaticResource AccentMistBrush}" />
                      <Setter Property="BorderBrush" Value="{StaticResource AccentRingBrush}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                      <Setter Property="BorderBrush" Value="{StaticResource WarningRingBrush}" />
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource MicroBadgeTextStyle}">
                    <Setter Property="Text" Value="Available" />
                    <Style.Triggers>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="Default" />
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="False" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="Added" />
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="Removed" />
                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Border>
          </Grid>
          <TextBlock Text="{Binding Description}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </CheckBox>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:MaintenanceActionCardViewModel}" x:Key="MaintenanceTemplate">
      <Border Margin="0,0,0,12">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
            <Setter Property="Padding" Value="16" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Margin="0,0,18,0">
            <TextBlock Text="{Binding Title}"
                       Foreground="{StaticResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="14"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding Description}"
                       Style="{StaticResource BodyTextStyle}"
                       Margin="0,6,0,0" />
            <TextBlock Margin="0,10,0,0">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                  <Setter Property="Text" Value="Runs here and leaves the result visible when LibreSpot finishes." />
                  <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                      <Setter Property="Text" Value="Use only when you want to clear the current setup and rebuild from scratch." />
                      <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>

          <Button Grid.Column="1"
                  MinWidth="150"
                  Height="42"
                  Padding="16,0"
                  Content="{Binding ButtonText}"
                  AutomationProperties.Name="{Binding ButtonText}"
                  AutomationProperties.HelpText="{Binding Description}"
                  Command="{Binding Command}">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:SelectionInsightViewModel}" x:Key="SelectionInsightTemplate">
      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Width="4"
                Height="14"
                CornerRadius="2"
                Margin="0,3,10,0"
                VerticalAlignment="Top">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Background" Value="{StaticResource StrokeBrush}" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding Tone}" Value="accent">
                  <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="warning">
                  <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
        </Border>
        <StackPanel Grid.Column="1">
          <TextBlock Text="{Binding Title}"
                     FontWeight="SemiBold"
                     FontSize="12.5"
                     Margin="0,0,0,4">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Tone}" Value="accent">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Tone}" Value="warning">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <TextBlock Text="{Binding Detail}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="SelectionBadgeTemplate">
      <Border Style="{StaticResource MicroBadgeStyle}"
              Background="{StaticResource Surface3Brush}"
              BorderBrush="{StaticResource StrokeBrush}"
              Margin="0,0,8,8">
        <TextBlock Text="{Binding}"
                   Style="{StaticResource MicroBadgeTextStyle}"
                   Foreground="{StaticResource TextBrush}" />
      </Border>
    </DataTemplate>

    <!--
      Overlay card style: fade + subtle scale-in when the bound IsVisible flag
      transitions False→True. DataTrigger EnterActions run on every transition,
      unlike EventTrigger RoutedEvent="Loaded" which fires only on first tree
      attachment — a Visibility toggle doesn't re-fire Loaded.
    -->
    <Style x:Key="ActivityCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
      <Setter Property="Background" Value="{StaticResource PanelStrongBrush}" />
      <Setter Property="Effect" Value="{StaticResource OverlayShadow}" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsActivityVisible}" Value="True">
          <DataTrigger.EnterActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.220">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                 From="0.97" To="1" Duration="0:0:0.260">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                 From="0.97" To="1" Duration="0:0:0.260">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="PromptCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
      <Setter Property="Background" Value="{StaticResource PanelStrongBrush}" />
      <Setter Property="Effect" Value="{StaticResource OverlayShadow}" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsPromptVisible}" Value="True">
          <DataTrigger.EnterActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.200">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                 From="0.97" To="1" Duration="0:0:0.240">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                 From="0.97" To="1" Duration="0:0:0.240">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Background="{StaticResource CanvasBrush}">
    <Grid Margin="24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="300" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- ═══ Sidebar ═══ -->
      <Border Grid.Column="0"
              Background="{StaticResource RailBrush}"
              BorderBrush="{StaticResource StrokeSoftBrush}"
              BorderThickness="1"
              CornerRadius="22"
              Padding="20">
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="LIBRESPOT"
                       Style="{StaticResource SectionEyebrowTextStyle}"
                       Foreground="{StaticResource AccentBrush}" />
            <TextBlock Text="Spotify setup, repair, and recovery"
                       Style="{StaticResource RailTitleTextStyle}"
                       FontSize="21"
                       Margin="0,8,0,0" />
            <TextBlock Text="Recommended handles the stable path, Custom keeps deliberate changes visible, and Maintenance stays reserved for recovery work."
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,10,0,0" />

            <Border Height="1"
                    Background="{StaticResource StrokeSoftBrush}"
                    Margin="0,18,0,18" />

            <TextBlock Text="Environment" Style="{StaticResource SectionEyebrowTextStyle}" />
            <Border Style="{StaticResource MetricCardStyle}">
              <StackPanel>
                <TextBlock Text="{Binding Snapshot.StatusTitle}"
                           Foreground="{StaticResource TextBrush}"
                           FontFamily="{StaticResource HeadingFont}"
                           FontSize="17"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Snapshot.StatusDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,6,0,14" />

                <!-- Status rows -->
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border>
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource StatusMarkerStyle}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Snapshot.SpotifyInstalled}" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding SpotifyStatusLine}" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource MutedTextBrush}" />
                </Grid>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border>
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource StatusMarkerStyle}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Snapshot.SpicetifyInstalled}" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding CustomizationStatusLine}" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource MutedTextBrush}" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border>
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource StatusMarkerStyle}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding HasConfigurationRecoveryNotice}" Value="True">
                            <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Snapshot.SavedConfigExists}" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding ProfileStatusLine}" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource MutedTextBrush}" />
                </Grid>
              </StackPanel>
            </Border>

            <TextBlock Text="Next step" Style="{StaticResource SectionEyebrowTextStyle}" Margin="0,20,0,8" />
            <TextBlock Text="{Binding WorkspaceRecommendationTitle}"
                       Foreground="{StaticResource TextBrush}"
                       FontFamily="{StaticResource HeadingFont}"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding WorkspaceRecommendationBrief}"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,6,0,0" />
            <TextBlock Text="{Binding RecommendedRunDuration}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,10,0,0" />

            <TextBlock Text="Profile recovery"
                       Style="{StaticResource SectionEyebrowTextStyle}"
                       Margin="0,22,0,10"
                       Visibility="{Binding HasConfigurationRecoveryNotice, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Border Style="{StaticResource SubtleCardStyle}"
                    Background="{StaticResource WarningSoftBrush}"
                    BorderBrush="{StaticResource WarningRingBrush}"
                    Visibility="{Binding HasConfigurationRecoveryNotice, Converter={StaticResource BoolToVisibilityConverter}}">
              <StackPanel>
                <TextBlock Text="{Binding ConfigurationRecoveryTitle}"
                           Foreground="{StaticResource TextBrush}"
                           FontFamily="{StaticResource HeadingFont}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ConfigurationRecoveryDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,6,0,0" />
                <Button Content="Open LibreSpot folder"
                        Height="40"
                        Margin="0,14,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.Name="Open LibreSpot folder"
                        AutomationProperties.HelpText="Opens the LibreSpot configuration folder so you can inspect the recovered profile backup."
                        Command="{Binding OpenLibreSpotFolderCommand}" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom" Margin="0,24,0,0">
            <Button Content="Refresh environment"
                    Style="{StaticResource GhostButtonStyle}"
                    Height="40"
                    ToolTip="Recheck Spotify, Spicetify, and saved profile state."
                    AutomationProperties.Name="Refresh environment"
                    AutomationProperties.HelpText="Rechecks the current Spotify, Spicetify, and saved profile state."
                    Command="{Binding RefreshSnapshotCommand}" />
            <Border Margin="0,12,0,0">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
                  <Setter Property="Background" Value="{StaticResource Surface1Brush}" />
                  <Setter Property="BorderBrush" Value="{StaticResource StrokeSoftBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSnapshotStale}" Value="True">
                      <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                      <Setter Property="BorderBrush" Value="{StaticResource WarningRingBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="STACK SNAPSHOT">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSnapshotStale}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding SnapshotFreshnessTitle}"
                           Foreground="{StaticResource TextBrush}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding SnapshotFreshnessDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{StaticResource SubtleTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
              </StackPanel>
            </Border>
            <TextBlock Text="Refresh after changing Spotify outside LibreSpot so recommendations stay accurate."
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{StaticResource SubtleTextBrush}"
                       TextAlignment="Left"
                       Margin="0,10,0,0" />
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ═══ Main content ═══ -->
      <Border Grid.Column="1"
              Margin="22,0,0,0"
              Style="{StaticResource SurfaceCardStyle}"
              Padding="28">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,24,0">
              <TextBlock Text="{Binding WorkspaceHeroEyebrow}"
                         Style="{StaticResource SectionEyebrowTextStyle}"
                         Foreground="{StaticResource AccentBrush}" />
              <TextBlock Text="{Binding WorkspaceHeroTitle}"
                         Style="{StaticResource HeadlineTextStyle}"
                         FontSize="28"
                         Margin="0,8,0,0" />
              <TextBlock Text="{Binding WorkspaceHeroBody}"
                         Style="{StaticResource CaptionTextStyle}"
                         Margin="0,10,0,0"
                         MaxWidth="760"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
              <TextBlock Text="{Binding SessionAccessTitle}"
                         Style="{StaticResource LabelTextStyle}"
                         TextAlignment="Right" />
              <TextBlock Text="{Binding SessionAccessDetail}"
                         Style="{StaticResource CaptionTextStyle}"
                         TextAlignment="Right"
                         TextWrapping="Wrap"
                         Width="260"
                         Margin="0,6,0,0" />
              <Button Content="Relaunch as administrator"
                      Height="40"
                      Margin="0,14,0,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      AutomationProperties.Name="Relaunch LibreSpot as administrator"
                      AutomationProperties.HelpText="Restarts LibreSpot with administrator access before applying changes."
                      Visibility="{Binding NeedsAdministratorRelaunch, Converter={StaticResource BoolToVisibilityConverter}}"
                      Command="{Binding RelaunchAsAdministratorCommand}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Height="1"
                    Background="{StaticResource StrokeSoftBrush}"
                    Margin="0,18,0,0" />
          </Grid>

          <!-- Workspace tabs -->
          <TabControl Grid.Row="1"
                      Style="{StaticResource WorkspaceTabControlStyle}"
                      SelectedIndex="{Binding SelectedWorkspaceIndex}">
            <TabControl.ItemContainerStyle>
              <Style TargetType="TabItem" BasedOn="{StaticResource WorkspaceTabItemStyle}" />
            </TabControl.ItemContainerStyle>

            <!-- ═══ Recommended (condensed: big apply button first, everything else below) ═══ -->
            <TabItem Header="Recommended">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,12,0,0">
                  <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="1.1*" />
                      <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,14,0">
                      <StackPanel>
                        <TextBlock Text="Recommended setup"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   FontSize="22" />
                        <TextBlock Text="{Binding WorkspaceRecommendationDetail}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,8,0,0" />

                        <Button Height="58"
                                Margin="0,20,0,0"
                                FontSize="17"
                                Style="{StaticResource PrimaryButtonStyle}"
                                AutomationProperties.Name="Run recommended setup"
                                AutomationProperties.HelpText="Runs LibreSpot's most reliable install path with the saved default profile."
                                Command="{Binding ApplyRecommendedCommand}">
                          <StackPanel Orientation="Horizontal">
                            <Path Width="22" Height="22"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"
                                  Stroke="{StaticResource TextOnAccentBrush}"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 12 2 L 12 11 M 5 6 A 9 9 0 1 0 19 6" />
                            <TextBlock Text="Run recommended setup" VerticalAlignment="Center" />
                          </StackPanel>
                        </Button>

                        <TextBlock Text="{Binding RecommendedRunDuration}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,12,0,0"
                                   Foreground="{StaticResource MutedTextBrush}" />
                      </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                      <TextBlock Text="What it includes"
                                 Style="{StaticResource SectionTitleTextStyle}"
                                 FontSize="17" />
                      <ItemsControl ItemsSource="{Binding RecommendedHighlights}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid Margin="0,0,0,10">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <Border Width="4"
                                      Height="14"
                                      CornerRadius="2"
                                      Background="{StaticResource AccentBrush}"
                                      Margin="0,4,10,0"
                                      VerticalAlignment="Top" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding}"
                                         Style="{StaticResource CaptionTextStyle}"
                                         Foreground="{StaticResource TextBrush}" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="{Binding RecommendedFollowUpText}"
                                 Style="{StaticResource CaptionTextStyle}"
                                 Foreground="{StaticResource MutedTextBrush}"
                                 Margin="0,14,0,0"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>

                  <Border Height="1"
                          Background="{StaticResource StrokeSoftBrush}"
                          Margin="0,0,0,16" />

                  <TextBlock Text="Use Recommended for first installs, repairs after a Spotify update, or any time you want the fastest path back to a known-good setup."
                             Style="{StaticResource CaptionTextStyle}"
                             Foreground="{StaticResource TextBrush}"
                             MaxWidth="780"
                             TextWrapping="Wrap" />
                </StackPanel>
              </ScrollViewer>
            </TabItem>

            <!-- ═══ Custom ═══ -->
            <TabItem Header="Custom">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,0,22,0">
                  <StackPanel>
                    <TextBlock Text="Find a setting"
                               Style="{StaticResource LabelTextStyle}" />
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBox Text="{Binding SettingsSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource TextBoxStylePremium}"
                               Height="42"
                               AutomationProperties.Name="Find a setting"
                               AutomationProperties.HelpText="Search setting titles and descriptions across the Custom page." />
                      <Button Grid.Column="1"
                              Content="Clear"
                              Height="42"
                              Margin="10,0,0,0"
                              Padding="18,0"
                              Style="{StaticResource SecondaryButtonStyle}"
                              Visibility="{Binding HasSettingsSearchText, Converter={StaticResource BoolToVisibilityConverter}}"
                              Command="{Binding ClearSettingsSearchCommand}" />
                    </Grid>
                    <TextBlock Text="{Binding CustomSearchSummary}"
                               Style="{StaticResource CaptionTextStyle}"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,10,0,18"
                               MaxWidth="760"
                               TextWrapping="Wrap" />

                    <Border Style="{StaticResource SubtleCardStyle}"
                            Background="{StaticResource Surface1Brush}"
                            Margin="0,0,0,18"
                            Visibility="{Binding ShowCustomSearchEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="4"
                                Height="38"
                                CornerRadius="2"
                                Background="{StaticResource StrokeStrongBrush}"
                                Margin="0,2,12,0"
                                VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="No matching settings"
                                     Style="{StaticResource EmptyStateTitleTextStyle}" />
                          <TextBlock Text="Try a broader term, or clear the search to browse the full profile again."
                                     Style="{StaticResource EmptyStateBodyTextStyle}"
                                     Margin="0,6,0,0" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <Border Style="{StaticResource MinimalSectionStyle}"
                            Visibility="{Binding HasVisibleInstallOptions, Converter={StaticResource BoolToVisibilityConverter}}">
                      <StackPanel>
                        <TextBlock Text="Install posture" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Choose whether LibreSpot rebuilds first and whether Spotify reopens when the run finishes."
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,6,0,14" />
                        <ItemsControl ItemsSource="{Binding InstallOptions}" ItemTemplate="{StaticResource OptionTemplate}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                        </ItemsControl>
                      </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MinimalSectionStyle}"
                            Visibility="{Binding HasVisibleAppearanceSettings, Converter={StaticResource BoolToVisibilityConverter}}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="1.15*" />
                          <ColumnDefinition Width="0.85*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                          <TextBlock Text="Appearance" Style="{StaticResource SectionTitleTextStyle}" />
                          <TextBlock Text="Theme, scheme, lyrics, cache, and compatibility."
                                     Style="{StaticResource BodyTextStyle}"
                                     Margin="0,6,0,16" />

                          <TextBlock Text="Theme pack" Style="{StaticResource LabelTextStyle}" />
                          <ComboBox ItemsSource="{Binding ThemeNames}"
                                     SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                     Style="{StaticResource ComboBoxStylePremium}"
                                     AutomationProperties.Name="Theme pack"
                                     AutomationProperties.HelpText="Select the Spicetify theme pack LibreSpot should restore."
                                     Margin="0,6,0,14" />

                          <TextBlock Text="Color scheme" Style="{StaticResource LabelTextStyle}" />
                          <ComboBox ItemsSource="{Binding SchemeOptions}"
                                     SelectedItem="{Binding SelectedScheme, Mode=TwoWay}"
                                     Style="{StaticResource ComboBoxStylePremium}"
                                     IsEnabled="{Binding IsThemeSchemeAvailable}"
                                     AutomationProperties.Name="Color scheme"
                                     AutomationProperties.HelpText="{Binding ThemeSchemeHint}"
                                     Margin="0,6,0,6">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource PrettifyConverter}}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <TextBlock Text="{Binding ThemeSchemeHint}"
                                     Style="{StaticResource CaptionTextStyle}"
                                     Margin="0,0,0,14" />

                          <TextBlock Text="Lyrics theme" Style="{StaticResource LabelTextStyle}" />
                          <ComboBox ItemsSource="{Binding LyricsThemes}"
                                     SelectedItem="{Binding SelectedLyricsTheme, Mode=TwoWay}"
                                     Style="{StaticResource ComboBoxStylePremium}"
                                     IsEnabled="{Binding IsLyricsThemeAvailable}"
                                     AutomationProperties.Name="Lyrics theme"
                                     AutomationProperties.HelpText="{Binding LyricsThemeHint}"
                                     Margin="0,6,0,6">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource PrettifyConverter}}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <TextBlock Text="{Binding LyricsThemeHint}"
                                     Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                          <TextBlock Text="Cache limit" Style="{StaticResource LabelTextStyle}" />
                          <Grid Margin="0,6,0,8">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding CacheLimitText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStylePremium}"
                                     MaxLength="6"
                                     AutomationProperties.Name="Cache limit in megabytes"
                                     AutomationProperties.HelpText="Set a cache ceiling in megabytes, or leave zero to use LibreSpot's default."
                                     DataObject.Pasting="CacheLimitTextBox_OnPasting"
                                     PreviewTextInput="CacheLimitTextBox_OnPreviewTextInput" />
                            <TextBlock Grid.Column="1"
                                       Text="MB"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0" />
                          </Grid>
                          <TextBlock Text="Leave 0 for the default cache behavior."
                                     Style="{StaticResource CaptionTextStyle}" />

                          <Border Height="1"
                                  Background="{StaticResource StrokeSoftBrush}"
                                  Margin="0,16,0,16" />

                          <TextBlock Text="Compatibility target"
                                     Style="{StaticResource LabelTextStyle}" />
                          <TextBlock Text="Spotify build"
                                     Style="{StaticResource SectionTitleTextStyle}"
                                     FontSize="16"
                                     Margin="0,6,0,0" />
                          <ComboBox ItemsSource="{Binding SpotifyVersionOptions}"
                                     SelectedValue="{Binding SelectedSpotifyVersionId, Mode=TwoWay}"
                                     SelectedValuePath="Id"
                                     Style="{StaticResource ComboBoxStylePremium}"
                                     AutomationProperties.Name="Spotify compatibility target"
                                     AutomationProperties.HelpText="Choose the Spotify build LibreSpot should pin when you want more explicit compatibility control."
                                     Margin="0,10,0,6">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Label}" TextWrapping="Wrap" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <TextBlock Text="{Binding SpotifyVersionNotes}"
                                     Style="{StaticResource CaptionTextStyle}" />

                          <TextBlock Text="Download path"
                                     Style="{StaticResource LabelTextStyle}"
                                     Margin="0,16,0,0" />
                          <ComboBox ItemsSource="{Binding DownloadMethodOptions}"
                                     SelectedValue="{Binding SelectedDownloadMethod, Mode=TwoWay}"
                                     SelectedValuePath="Id"
                                     Style="{StaticResource ComboBoxStylePremium}"
                                     AutomationProperties.Name="Download method"
                                     AutomationProperties.HelpText="Override LibreSpot's default transfer path only when your network or environment calls for it."
                                     Margin="0,10,0,6">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Label}" TextWrapping="Wrap" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <TextBlock Text="{Binding DownloadMethodDetail}"
                                     Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <Border Style="{StaticResource MinimalSectionStyle}"
                            Visibility="{Binding HasVisibleBehaviorSection, Converter={StaticResource BoolToVisibilityConverter}}">
                      <StackPanel>
                        <TextBlock Text="Playback and shell behavior" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="These settings shape the day-to-day Spotify experience after patching."
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,6,0,14" />

                        <TextBlock Text="Core behavior"
                                   Style="{StaticResource LabelTextStyle}"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding HasVisibleCoreOptions, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding CoreOptions}" ItemTemplate="{StaticResource OptionTemplate}">
                          <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVisibleCoreOptions}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ItemsControl.Style>
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <Border Height="1"
                                Background="{StaticResource StrokeSoftBrush}"
                                Margin="0,8,0,14">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVisibleCoreOptions}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasVisibleInterfaceOptions}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                        </Border>

                        <TextBlock Text="Interface tuning"
                                   Style="{StaticResource LabelTextStyle}"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding HasVisibleInterfaceOptions, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding InterfaceOptions}" ItemTemplate="{StaticResource OptionTemplate}">
                          <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVisibleInterfaceOptions}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ItemsControl.Style>
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                        </ItemsControl>
                      </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MinimalSectionStyle}"
                            Visibility="{Binding HasVisibleAdvancedSection, Converter={StaticResource BoolToVisibilityConverter}}">
                      <StackPanel>
                        <TextBlock Text="Advanced adjustments" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Leave these off unless you know you need them."
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,6,0,14" />
                        <ItemsControl ItemsSource="{Binding AdvancedOptions}" ItemTemplate="{StaticResource OptionTemplate}">
                          <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVisibleAdvancedOptions}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ItemsControl.Style>
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <Border Height="1"
                                Background="{StaticResource StrokeSoftBrush}"
                                Margin="0,8,0,14">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVisibleAdvancedOptions}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasVisibleExperienceOptions}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                        </Border>

                        <TextBlock Text="Experience extras"
                                   Style="{StaticResource LabelTextStyle}"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding HasVisibleExperienceOptions, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding ExperienceOptions}" ItemTemplate="{StaticResource OptionTemplate}">
                          <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVisibleExperienceOptions}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ItemsControl.Style>
                        </ItemsControl>
                      </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MinimalSectionStyle}"
                            BorderThickness="0"
                            Visibility="{Binding HasVisibleExtensions, Converter={StaticResource BoolToVisibilityConverter}}">
                      <StackPanel>
                        <TextBlock Text="Built-in extensions" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Extras LibreSpot manages with this profile."
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,6,0,14" />
                        <ItemsControl ItemsSource="{Binding Extensions}" ItemTemplate="{StaticResource ExtensionTemplate}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </ScrollViewer>

                <!-- Sticky selection summary -->
                <Border Grid.Column="1"
                        Style="{StaticResource SubtleCardStyle}"
                        Background="{StaticResource Surface1Brush}"
                        BorderBrush="{StaticResource StrokeSoftBrush}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="*" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                      <StackPanel>
                        <TextBlock Text="Profile summary"
                                   Style="{StaticResource LabelTextStyle}"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding CustomProfileTitle}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="18"
                                   Margin="0,8,0,4" />
                        <TextBlock Text="{Binding CustomProfileDetail}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Foreground="{StaticResource TextBrush}" />

                        <Border Height="1"
                                Background="{StaticResource StrokeSoftBrush}"
                                Margin="0,16,0,16" />

                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="106" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>

                          <TextBlock Text="Install posture"
                                     Style="{StaticResource LabelTextStyle}"
                                     Margin="0,2,12,0" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding InstallPostureLabel}"
                                     Foreground="{StaticResource TextBrush}"
                                     FontWeight="SemiBold"
                                     FontSize="13"
                                     TextWrapping="Wrap" />

                          <TextBlock Grid.Row="1"
                                     Text="Profile changes"
                                     Style="{StaticResource LabelTextStyle}"
                                     Margin="0,12,12,0" />
                          <TextBlock Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding CustomChangeCountLabel}"
                                     Foreground="{StaticResource TextBrush}"
                                     FontWeight="SemiBold"
                                     FontSize="13"
                                     TextWrapping="Wrap"
                                     Margin="0,12,0,0" />

                          <TextBlock Grid.Row="2"
                                     Text="Extensions"
                                     Style="{StaticResource LabelTextStyle}"
                                     Margin="0,12,12,0" />
                          <TextBlock Grid.Row="2"
                                     Grid.Column="1"
                                     Text="{Binding SelectedExtensionCountLabel}"
                                     Foreground="{StaticResource TextBrush}"
                                     FontWeight="SemiBold"
                                     FontSize="13"
                                     TextWrapping="Wrap"
                                     Margin="0,12,0,0" />

                          <TextBlock Grid.Row="3"
                                     Text="Access"
                                     Style="{StaticResource LabelTextStyle}"
                                     Margin="0,12,12,0" />
                          <TextBlock Grid.Row="3"
                                     Grid.Column="1"
                                     Text="{Binding AccessPostureLabel}"
                                     Foreground="{StaticResource TextBrush}"
                                     FontWeight="SemiBold"
                                     FontSize="13"
                                     TextWrapping="Wrap"
                                     Margin="0,12,0,0" />
                        </Grid>

                        <Border Height="1"
                                Background="{StaticResource StrokeSoftBrush}"
                                Margin="0,16,0,16" />

                        <TextBlock Text="Run readiness"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding CustomRunReadinessTitle}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,4,0,6"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding CustomRunReadinessDetail}"
                                   Style="{StaticResource CaptionTextStyle}" />

                        <Border Height="1"
                                Background="{StaticResource StrokeSoftBrush}"
                                Margin="0,16,0,16" />

                        <TextBlock Text="Current selections"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ThemeSummary}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding LyricsSummary}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="{Binding CacheSummary}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding CustomSelectionSummary}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="Compatibility target"
                                   Style="{StaticResource LabelTextStyle}"
                                   Margin="0,12,0,0" />
                        <TextBlock Text="{Binding SpotifyVersionSummary}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SpotifyVersionNotes}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="Download route"
                                   Style="{StaticResource LabelTextStyle}"
                                   Margin="0,12,0,0" />
                        <TextBlock Text="{Binding DownloadMethodSummary}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DownloadMethodDetail}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0" />

                        <Border Height="1"
                                Background="{StaticResource StrokeSoftBrush}"
                                Margin="0,16,0,16" />

                        <TextBlock Text="What to watch"
                                   Style="{StaticResource LabelTextStyle}" />
                        <ItemsControl ItemsSource="{Binding SelectionInsights}"
                                      ItemTemplate="{StaticResource SelectionInsightTemplate}"
                                      Margin="0,10,0,0" />

                        <Border Height="1"
                                Background="{StaticResource StrokeSoftBrush}"
                                Margin="0,6,0,16" />

                        <TextBlock Text="Extensions"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ExtensionSummary}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="0,6,0,8"
                                   TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding SelectedExtensionLabels}"
                                      ItemTemplate="{StaticResource SelectionBadgeTemplate}">
                          <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedExtensions}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ItemsControl.Style>
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <StackPanel Margin="0,0,0,0">
                          <StackPanel.Style>
                            <Style TargetType="StackPanel">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedExtensions}" Value="False">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </StackPanel.Style>
                          <TextBlock Text="No extensions selected"
                                     Foreground="{StaticResource TextBrush}"
                                     FontWeight="SemiBold"
                                     FontSize="12.5" />
                          <TextBlock Text="Keep it lean, or add helpers only when you need them."
                                     Style="{StaticResource CaptionTextStyle}"
                                     Margin="0,6,0,0" />
                        </StackPanel>
                      </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="1"
                            Content="Apply custom profile"
                            Height="48"
                            Margin="0,16,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            AutomationProperties.Name="Apply custom profile"
                            AutomationProperties.HelpText="Saves this custom profile and runs it through the backend installer."
                            Command="{Binding ApplyCustomCommand}" />
                    <TextBlock Grid.Row="2"
                               Text="{Binding CustomApplyCaption}"
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,10,0,0"
                               TextAlignment="Center" />
                  </Grid>
                </Border>
              </Grid>
            </TabItem>

            <!-- ═══ Maintenance ═══ -->
            <TabItem Header="Maintenance">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,12,0,0">
                  <TextBlock Text="{Binding MaintenanceGuidanceTitle}"
                             Style="{StaticResource SectionTitleTextStyle}"
                             FontSize="22" />
                  <TextBlock Text="{Binding MaintenanceGuidanceDetail}"
                             Style="{StaticResource CaptionTextStyle}"
                             Foreground="{StaticResource TextBrush}"
                             Margin="0,8,0,0"
                             MaxWidth="780"
                             TextWrapping="Wrap" />

                  <Border Height="1"
                          Background="{StaticResource StrokeSoftBrush}"
                          Margin="0,18,0,18" />

                  <Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                      <TextBlock Text="Refresh and recover"
                                 Style="{StaticResource SectionTitleTextStyle}"
                                 FontSize="18" />
                      <TextBlock Text="Use these first for checks, reapply, and lighter rollback work."
                                 Style="{StaticResource CaptionTextStyle}"
                                 Foreground="{StaticResource TextBrush}"
                                 Margin="0,8,0,12" />
                      <ItemsControl ItemsSource="{Binding SafeMaintenanceActions}"
                                    ItemTemplate="{StaticResource MaintenanceTemplate}" />
                    </StackPanel>
                  </Border>

                  <Border Style="{StaticResource SubtleCardStyle}"
                          Background="{StaticResource Surface1Brush}"
                          BorderBrush="{StaticResource StrokeSoftBrush}">
                    <StackPanel>
                      <TextBlock Text="Reset"
                                 Style="{StaticResource SectionTitleTextStyle}"
                                 FontSize="18"
                                 Foreground="{StaticResource DangerBrush}" />
                      <TextBlock Text="Use only when you want to remove the current setup and start from a cleaner baseline."
                                 Style="{StaticResource CaptionTextStyle}"
                                 Foreground="{StaticResource TextBrush}"
                                 Margin="0,8,0,12" />
                      <ItemsControl ItemsSource="{Binding DestructiveMaintenanceActions}"
                                    ItemTemplate="{StaticResource MaintenanceTemplate}" />
                    </StackPanel>
                  </Border>

                  <TextBlock Text="Close Spotify first if playback is active, and copy the log if anything looks unusual."
                             Style="{StaticResource CaptionTextStyle}"
                             Foreground="{StaticResource MutedTextBrush}"
                             Margin="0,16,0,0"
                             MaxWidth="760"
                             TextWrapping="Wrap" />
                </StackPanel>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Grid>
      </Border>
    </Grid>

    <!-- ═══ Activity overlay ═══ -->
    <Grid Visibility="{Binding IsActivityVisible, Converter={StaticResource BoolToVisibilityConverter}}"
          KeyboardNavigation.TabNavigation="Cycle">
      <!-- Scrim -->
      <Border x:Name="ActivityScrim"
              Background="{StaticResource OverlayBrush}">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsActivityVisible}" Value="True">
                <DataTrigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       From="0" To="1" Duration="0:0:0.180">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.EnterActions>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>
      <Grid Margin="64">
        <Border x:Name="ActivityDialogRoot"
                Width="900"
                MaxHeight="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="32"
                Focusable="True"
                AutomationProperties.Name="Run activity dialog"
                AutomationProperties.HelpText="Shows live backend progress, current status, and troubleshooting output."
                Style="{StaticResource ActivityCardStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{Binding ActivityBadgeText}"
                           AutomationProperties.Name="Run status"
                           AutomationProperties.LiveSetting="Polite">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding ActivityTitle}" Style="{StaticResource SectionTitleTextStyle}" FontSize="24" />
                <TextBlock Text="{Binding ActivityStatus}"
                           Style="{StaticResource BodyTextStyle}"
                           AutomationProperties.LiveSetting="Polite"
                           Margin="0,6,0,0" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="20,0,0,0">
                <TextBlock Text="Elapsed"
                           Style="{StaticResource LabelTextStyle}"
                           TextAlignment="Right" />
                <TextBlock Text="{Binding RunElapsedText}"
                           Foreground="{StaticResource TextBrush}"
                           FontFamily="{StaticResource MonoFont}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,6,0,0"
                           TextAlignment="Right" />
              </StackPanel>
            </Grid>

            <!-- Progress -->
            <Border Grid.Row="1" Style="{StaticResource SubtleCardStyle}" Margin="0,20,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar Height="8"
                             Maximum="100"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             IsIndeterminate="{Binding IsBusyIndeterminate, Mode=OneWay}"
                             Style="{StaticResource ProgressBarStylePremium}"
                             VerticalAlignment="Center" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                  <TextBlock Text="{Binding ProgressLabel}"
                             VerticalAlignment="Center"
                             FontFamily="{StaticResource MonoFont}"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextBrush}"
                             MinWidth="72" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Current step -->
            <Border Grid.Row="2"
                    Margin="0,14,0,0">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
                  <Setter Property="Background" Value="{StaticResource Surface1Brush}" />
                  <Setter Property="BorderBrush" Value="{StaticResource StrokeSoftBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                      <Setter Property="BorderBrush" Value="{StaticResource AccentRingBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                      <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                      <Setter Property="BorderBrush" Value="{StaticResource WarningRingBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="4"
                        Height="18"
                        CornerRadius="2"
                        Margin="0,2,12,0"
                        VerticalAlignment="Top">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="{StaticResource StrokeBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                          <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                          <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                          <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                </Border>
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding ActivityDetailLabel}">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                          </DataTrigger>
                          <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                              <Condition Binding="{Binding IsRunning}" Value="False" />
                              <Condition Binding="{Binding IsActivityError}" Value="False" />
                              <Condition Binding="{Binding IsActivityCanceled}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                          </MultiDataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <TextBlock Text="{Binding ActivityStep}"
                             Margin="0,4,0,0"
                             Foreground="{StaticResource TextBrush}"
                             FontWeight="SemiBold"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Log -->
            <Grid Grid.Row="3" Margin="0,20,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="BACKEND LOG"
                             Style="{StaticResource LabelTextStyle}"
                             VerticalAlignment="Center" />
                  <TextBlock Text="Live PowerShell output from the backend."
                             Style="{StaticResource CaptionTextStyle}"
                             Margin="0,6,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding LogLineCountText}"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{StaticResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
              </Grid>
              <Border Grid.Row="1"
                      MinHeight="220"
                      Background="#080B0A"
                      BorderBrush="{StaticResource StrokeBrush}"
                      BorderThickness="1"
                      CornerRadius="12">
                <Grid>
                  <!-- Empty state -->
                  <StackPanel HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              MaxWidth="420"
                              Visibility="{Binding IsLogEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Backend output will appear here"
                               Style="{StaticResource EmptyStateTitleTextStyle}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Progress, warnings, and recovery clues are captured as soon as the backend begins emitting output."
                               Style="{StaticResource EmptyStateBodyTextStyle}"
                               TextAlignment="Center"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center" />
                  </StackPanel>

                  <ScrollViewer x:Name="LogScrollViewer"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                AutomationProperties.Name="Backend log"
                                Padding="14,12">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,1">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TimestampDisplay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11.5"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       Margin="0,0,12,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Level}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                       MinWidth="58"
                                       Margin="0,0,12,0" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Message}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11.5"
                                       Foreground="#D6E4DB"
                                       TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>
            </Grid>

            <Grid Grid.Row="4" Margin="0,18,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel Margin="0,0,20,0">
                <TextBlock Text="{Binding ActivitySummaryTitle}"
                           Style="{StaticResource LabelTextStyle}" />
                <TextBlock Text="{Binding ActivityAssistiveText}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           MaxWidth="430" />
                <TextBlock Text="{Binding ActivityLogPathText}"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{StaticResource SubtleTextBrush}"
                           Margin="0,8,0,0"
                           MaxWidth="430"
                           TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          HorizontalAlignment="Right">
                <Button Content="Copy log"
                        x:Name="ActivityCopyLogButton"
                        MinWidth="120"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.Name="Copy backend log"
                        AutomationProperties.HelpText="Copies the visible backend log to the clipboard."
                        Command="{Binding CopyLogCommand}" />
                <Button Content="Open folder"
                        x:Name="ActivityOpenLibreSpotFolderButton"
                        MinWidth="132"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.Name="Open LibreSpot folder"
                        AutomationProperties.HelpText="Opens the LibreSpot configuration folder, including config backups and install.log."
                        Command="{Binding OpenLibreSpotFolderCommand}" />
                <Button Content="Cancel run"
                        x:Name="ActivityCancelRunButton"
                        MinWidth="140"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource DestructiveButtonStyle}"
                        AutomationProperties.Name="Cancel current run"
                        AutomationProperties.HelpText="Stops the active LibreSpot backend run."
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding CancelRunCommand}" />
                <Button Content="Close"
                        x:Name="ActivityCloseButton"
                        MinWidth="140"
                        Height="42"
                        Padding="18,0"
                        AutomationProperties.Name="Close activity panel"
                        AutomationProperties.HelpText="Dismisses the activity panel after the run is finished."
                        Command="{Binding DismissActivityCommand}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- ═══ Prompt overlay ═══ -->
    <Grid Visibility="{Binding IsPromptVisible, Converter={StaticResource BoolToVisibilityConverter}}"
          KeyboardNavigation.TabNavigation="Cycle">
      <Border Background="{StaticResource OverlayBrush}">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsPromptVisible}" Value="True">
                <DataTrigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       From="0" To="1" Duration="0:0:0.160">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.EnterActions>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>
      <Grid Margin="64">
        <Border x:Name="PromptDialogRoot"
                Width="540"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="30"
                AutomationProperties.Name="Decision prompt"
                AutomationProperties.HelpText="Confirms an important LibreSpot action before it runs."
                Style="{StaticResource PromptCardStyle}">
          <StackPanel>
            <TextBlock FontWeight="SemiBold"
                       FontSize="11">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                  <Setter Property="Text" Value="Confirm action" />
                  <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsPromptDestructive}" Value="True">
                      <Setter Property="Text" Value="Reset action" />
                      <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="{Binding PromptTitle}" Style="{StaticResource SectionTitleTextStyle}" FontSize="22" />
            <TextBlock Text="{Binding PromptBody}" Style="{StaticResource BodyTextStyle}" Margin="0,12,0,0" />
            <Border Height="1"
                    Background="{StaticResource StrokeSoftBrush}"
                    Margin="0,18,0,16" />
            <TextBlock Text="{Binding PromptSummaryTitle}">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsPromptDestructive}" Value="True">
                      <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding PromptSummaryBody}"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
              <Button Content="{Binding PromptCancelText}"
                      x:Name="PromptCancelButton"
                      MinWidth="160"
                      Height="42"
                      Padding="18,0"
                      Margin="0,0,10,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      AutomationProperties.Name="{Binding PromptCancelText}"
                      IsCancel="True"
                      Command="{Binding CancelPromptCommand}" />
              <Button MinWidth="200"
                      x:Name="PromptConfirmButton"
                      Height="42"
                      Padding="18,0"
                      Content="{Binding PromptConfirmText}"
                      AutomationProperties.Name="{Binding PromptConfirmText}"
                      Command="{Binding ConfirmPromptCommand}">
                <Button.Style>
                  <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsPromptDestructive}" Value="True">
                        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                        <Setter Property="Tag" Value="{StaticResource DangerHoverTintBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Button.Style>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
