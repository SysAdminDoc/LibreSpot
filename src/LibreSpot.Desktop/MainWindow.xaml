                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding MaintenanceMarketplaceValue}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding MaintenanceMarketplaceDetail}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,6,0,0" />
                      </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SubtleCardStyle}">
                      <StackPanel>
                        <TextBlock Text="{x:Static props:Strings.ThemeLabel}"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding MaintenanceThemeValue}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding MaintenanceThemeDetail}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,6,0,0" />
                      </StackPanel>
                    </Border>
                  </UniformGrid>

                  <Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,18,0">
                          <TextBlock Text="{x:Static props:Strings.SupportBundleTitle}"
                                     Style="{StaticResource SectionTitleTextStyle}"
                                     FontSize="18" />
                          <TextBlock Text="{Binding SupportBundlePreviewTitle}"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="SemiBold"
                                     Margin="0,8,0,0"
                                     TextWrapping="Wrap" />
                          <TextBlock Text="{Binding SupportBundlePreviewDetail}"
                                     Style="{StaticResource CaptionTextStyle}"
                                     Margin="0,4,0,0" />
                          <TextBlock Text="{Binding SupportBundleRedactionSummary}"
                                     Style="{StaticResource CaptionTextStyle}"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,8,0,0"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                MinWidth="170"
                                Height="42"
                                Padding="16,0"
                                Content="{x:Static props:Strings.ButtonExportBundle}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                AutomationProperties.Name="{x:Static props:Strings.ButtonExportBundleName}"
                                AutomationProperties.HelpText="{x:Static props:Strings.ButtonExportBundleHint}"
                                Command="{Binding ExportSupportBundleCommand}" />
                      </Grid>

                      <ItemsControl ItemsSource="{Binding SupportBundleItems}"
                                    ItemTemplate="{StaticResource SupportBundleCategoryTemplate}"
                                    Margin="0,16,0,0">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                      </ItemsControl>

                      <Border Height="1"
                              Background="{DynamicResource StrokeSoftBrush}"
                              Margin="0,8,0,14" />

                      <ItemsControl ItemsSource="{Binding SupportBundleRedactionRules}"
                                    Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid Margin="0,0,0,6">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <Border Width="4"
                                      Height="14"
                                      CornerRadius="2"
                                      Background="{DynamicResource AccentBrush}"
                                      Margin="0,3,10,0" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding}"
                                         Style="{StaticResource CaptionTextStyle}"
                                         TextWrapping="Wrap" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="{Binding SupportBundleLastExportText}"
                                 Style="{StaticResource CaptionTextStyle}"
                                 Foreground="{DynamicResource MutedTextBrush}"
                                 Margin="0,8,0,0"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>

                  <Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,0,14">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="{x:Static props:Strings.AutoReapplyTitle}"
                                     Style="{StaticResource SectionTitleTextStyle}"
                                     FontSize="18" />
                          <TextBlock Text="{Binding AutoReapplyStatusDetail}"
                                     Style="{StaticResource CaptionTextStyle}"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,8,0,0"
                                     MaxWidth="760"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Style="{StaticResource MicroBadgeStyle}"
                                Margin="18,0,0,0">
                          <TextBlock Text="{Binding AutoReapplyStatusTitle}"
                                     Style="{StaticResource MicroBadgeTextStyle}" />
                        </Border>
                      </Grid>

                      <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="4" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                CornerRadius="2">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding Snapshot.AutoReapplyTaskRegistered}" Value="True">
                                  <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                          <TextBlock Text="{Binding AutoReapplyTaskLine}"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                          <TextBlock Text="{Binding AutoReapplyLogLine}"
                                     Style="{StaticResource CaptionTextStyle}"
                                     Foreground="{DynamicResource SubtleTextBrush}"
                                     Margin="0,4,0,0"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>

                      <WrapPanel Grid.Row="2"
                                 Margin="0,18,0,0"
                                 HorizontalAlignment="Right">
                        <Button Content="{x:Static props:Strings.ButtonEnableWatcher}"
                                MinWidth="136"
                                Height="38"
                                Padding="16,0"
                                Margin="0,0,10,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                AutomationProperties.Name="{x:Static props:Strings.ButtonEnableWatcherName}"
                                AutomationProperties.HelpText="{x:Static props:Strings.ButtonEnableWatcherHint}"
                                Command="{Binding EnableAutoReapplyCommand}" />
                        <Button Content="{x:Static props:Strings.ButtonDisableWatcher}"
                                MinWidth="136"
                                Height="38"
                                Padding="16,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                AutomationProperties.Name="{x:Static props:Strings.ButtonDisableWatcherName}"
                                AutomationProperties.HelpText="{x:Static props:Strings.ButtonDisableWatcherHint}"
                                Command="{Binding DisableAutoReapplyCommand}" />
                      </WrapPanel>
                    </Grid>
                  </Border>

                  <Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                      <TextBlock Text="{x:Static props:Strings.RefreshRecoverSection}"
                                 Style="{StaticResource SectionTitleTextStyle}"
                                 FontSize="18" />
                      <TextBlock Text="{x:Static props:Strings.RefreshRecoverDescription}"
                                 Style="{StaticResource CaptionTextStyle}"
                                 Foreground="{DynamicResource TextBrush}"
                                 Margin="0,8,0,12" />
                      <ItemsControl ItemsSource="{Binding SafeMaintenanceActions}"
                                    ItemTemplate="{StaticResource MaintenanceTemplate}" />
                    </StackPanel>
                  </Border>

                  <Border Style="{StaticResource SubtleCardStyle}"
                          Background="{DynamicResource Surface1Brush}"
                          BorderBrush="{DynamicResource StrokeSoftBrush}">
                    <StackPanel>
                      <TextBlock Text="{x:Static props:Strings.ResetSection}"
                                 Style="{StaticResource SectionTitleTextStyle}"
                                 FontSize="18"
                                 Foreground="{DynamicResource DangerBrush}" />
                      <TextBlock Text="{x:Static props:Strings.ResetDescription}"
                                 Style="{StaticResource CaptionTextStyle}"
                                 Foreground="{DynamicResource TextBrush}"
                                 Margin="0,8,0,12" />
                      <ItemsControl ItemsSource="{Binding DestructiveMaintenanceActions}"
                                    ItemTemplate="{StaticResource MaintenanceTemplate}" />
                    </StackPanel>
                  </Border>

                  <TextBlock Text="{x:Static props:Strings.MaintenanceClosingHint}"
                             Style="{StaticResource CaptionTextStyle}"
                             Foreground="{DynamicResource MutedTextBrush}"
                             Margin="0,16,0,0"
                             MaxWidth="760"
                             TextWrapping="Wrap" />
                </StackPanel>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Grid>
      </Border>
    </Grid>

    <!-- ═══ Activity overlay ═══ -->
    <Grid Visibility="{Binding IsActivityVisible, Converter={StaticResource BoolToVisibilityConverter}}"
          KeyboardNavigation.TabNavigation="Cycle">
      <!-- Scrim -->
      <Border x:Name="ActivityScrim"
              Background="{DynamicResource OverlayBrush}">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsActivityVisible}" Value="True">
                <DataTrigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       From="0" To="1" Duration="{StaticResource MotionMedDuration}">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.EnterActions>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>
      <Grid Margin="64">
        <Border x:Name="ActivityDialogRoot"
                Width="900"
                MaxHeight="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="32"
                Focusable="True"
                AutomationProperties.AutomationId="ActivityDialogRoot"
                AutomationProperties.Name="{x:Static props:Strings.ActivityDialogName}"
                AutomationProperties.HelpText="{x:Static props:Strings.ActivityDialogHint}"
                Style="{StaticResource ActivityCardStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{Binding ActivityBadgeText}"
                           AutomationProperties.Name="{services:Loc Ui_RunState}">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding ActivityTitle}" Style="{StaticResource SectionTitleTextStyle}" FontSize="24" />
                <controls:LiveRegionContentControl Content="{Binding ActivityStatus}"
                                                   AutomationProperties.AutomationId="RunStatus"
                                                   AutomationProperties.Name="{services:Loc RunStatus}"
                                                   Margin="0,6,0,0">
                  <controls:LiveRegionContentControl.ContentTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" Style="{StaticResource BodyTextStyle}" />
                    </DataTemplate>
                  </controls:LiveRegionContentControl.ContentTemplate>
                </controls:LiveRegionContentControl>
              </StackPanel>
              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="20,0,0,0">
                <TextBlock Text="{x:Static props:Strings.ElapsedLabel}"
                           Style="{StaticResource LabelTextStyle}"
                           TextAlignment="Right" />
                <TextBlock Text="{Binding RunElapsedText}"
                           Foreground="{DynamicResource TextBrush}"
                           FontFamily="{StaticResource MonoFont}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,6,0,0"
                           TextAlignment="Right" />
              </StackPanel>
            </Grid>

            <!-- Progress -->
            <Border Grid.Row="1" Style="{StaticResource SubtleCardStyle}" Margin="0,20,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar Height="8"
                             Maximum="100"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             IsIndeterminate="{Binding IsBusyIndeterminate, Mode=OneWay}"
                             Style="{StaticResource ProgressBarStylePremium}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name="{x:Static props:Strings.ProgressBarName}" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                  <TextBlock Text="{Binding ProgressLabel}"
                             VerticalAlignment="Center"
                             FontFamily="{StaticResource MonoFont}"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextBrush}"
                             MinWidth="72" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Current step -->
            <Border Grid.Row="2"
                    Margin="0,14,0,0">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
                  <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                  <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                      <Setter Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                      <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                      <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="4"
                        Height="18"
                        CornerRadius="2"
                        Margin="0,2,12,0"
                        VerticalAlignment="Top">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                </Border>
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding ActivityDetailLabel}">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                          </DataTrigger>
                          <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                              <Condition Binding="{Binding IsRunning}" Value="False" />
                              <Condition Binding="{Binding IsActivityError}" Value="False" />
                              <Condition Binding="{Binding IsActivityCanceled}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                          </MultiDataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <TextBlock Text="{Binding ActivityStep}"
                             Margin="0,4,0,0"
                             Foreground="{DynamicResource TextBrush}"
                             FontWeight="SemiBold"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Log -->
            <Grid Grid.Row="3" Margin="0,20,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <Border Grid.Row="0"
                      Margin="0,0,0,14"
                      Background="{DynamicResource Surface1Brush}"
                      BorderBrush="{DynamicResource StrokeSoftBrush}"
                      BorderThickness="1"
                      CornerRadius="12"
                      Padding="16"
                      AutomationProperties.Name="{x:Static props:Strings.UndoPaneTitle}"
                      Visibility="{Binding HasUndoActionItems, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border Grid.Column="0"
                          Width="4"
                          CornerRadius="2"
                          Background="{DynamicResource AccentBrush}" />
                  <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="{x:Static props:Strings.UndoPaneTitle}"
                               Style="{StaticResource LabelTextStyle}"
                               Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="{x:Static props:Strings.UndoPaneDescription}"
                               Style="{StaticResource CaptionTextStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,4,0,10"
                               TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding UndoActionItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,3">
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{Binding Summary}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <Border Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource MicroBadgeStyle}"
                                    Margin="12,0,0,0">
                              <TextBlock Text="{Binding Action}"
                                         Style="{StaticResource MicroBadgeTextStyle}" />
                            </Border>
                            <Grid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,4,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Text="{x:Static props:Strings.UndoPaneUndoLabel}"
                                         Style="{StaticResource CaptionTextStyle}"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         FontWeight="SemiBold"
                                         Margin="0,0,6,0" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding RollbackHint}"
                                         Style="{StaticResource CaptionTextStyle}"
                                         Foreground="{DynamicResource SubtleTextBrush}"
                                         TextWrapping="Wrap" />
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Grid>
              </Border>

              <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="{x:Static props:Strings.RunLogLabel}"
                             Style="{StaticResource LabelTextStyle}"
                             VerticalAlignment="Center" />
                  <TextBlock Text="{x:Static props:Strings.RunLogDescription}"
                             Style="{StaticResource CaptionTextStyle}"
                             Margin="0,6,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding LogLineCountText}"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
              </Grid>
              <Border Grid.Row="2"
                      MinHeight="220"
                      Background="{DynamicResource TerminalBgBrush}"
                      BorderBrush="{DynamicResource StrokeBrush}"
                      BorderThickness="1"
                      CornerRadius="12">
                <Grid>
                  <!-- Empty state -->
                  <StackPanel HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              MaxWidth="420">
                    <StackPanel.Style>
                      <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding LogEntries.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{x:Static props:Strings.LogEmptyStateTitle}"
                               Style="{StaticResource EmptyStateTitleTextStyle}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Static props:Strings.LogEmptyStateHint}"
                               Style="{StaticResource EmptyStateBodyTextStyle}"
                               TextAlignment="Center"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center" />
                  </StackPanel>

                  <ScrollViewer x:Name="LogScrollViewer"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                AutomationProperties.Name="{services:Loc RunLogLabel}"
                                Padding="14,12">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,1">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TimestampDisplay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Margin="0,0,12,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Level}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                       MinWidth="58"
                                       Margin="0,0,12,0" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Message}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource TerminalFgBrush}"
                                       TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>
            </Grid>

            <Grid Grid.Row="4" Margin="0,18,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel Margin="0,0,20,0">
                <TextBlock Text="{Binding ActivitySummaryTitle}"
                           Style="{StaticResource LabelTextStyle}" />
                <TextBlock Text="{Binding ActivityAssistiveText}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           MaxWidth="430" />
                <TextBlock Text="{Binding ActivityLogPathText}"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           Margin="0,8,0,0"
                           MaxWidth="430"
                           TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          HorizontalAlignment="Right">
                <Button Content="{x:Static props:Strings.ButtonCopyLog}"
                        x:Name="ActivityCopyLogButton"
                        MinWidth="120"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.AutomationId="ActivityCopyLogButton"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonCopyLogName}"
                        AutomationProperties.HelpText="{x:Static props:Strings.ButtonCopyLogHint}"
                        Command="{Binding CopyLogCommand}" />
                <Button Content="{x:Static props:Strings.ButtonOpenFolder}"
                        x:Name="ActivityOpenLibreSpotFolderButton"
                        MinWidth="132"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.AutomationId="ActivityOpenLibreSpotFolderButton"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonOpenLibreSpotFolder}"
                        AutomationProperties.HelpText="{x:Static props:Strings.ButtonOpenLibreSpotFolderActivityHint}"
                        Command="{Binding OpenLibreSpotFolderCommand}" />
                <Button Content="{x:Static props:Strings.ButtonCancelRun}"
                        x:Name="ActivityCancelRunButton"
                        MinWidth="140"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource DestructiveButtonStyle}"
                        AutomationProperties.AutomationId="ActivityCancelRunButton"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonCancelRunName}"
                        AutomationProperties.HelpText="{x:Static props:Strings.ButtonCancelRunHint}"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding CancelRunCommand}" />
                <Button Content="{x:Static props:Strings.ButtonClose}"
                        x:Name="ActivityCloseButton"
                        MinWidth="140"
                        Height="42"
                        Padding="18,0"
                        AutomationProperties.AutomationId="ActivityCloseButton"
                        AutomationProperties.Name="{services:Loc Ui_CloseActivityPanel}"
                        AutomationProperties.HelpText="{services:Loc Ui_DismissesTheActivityPanelAfterTheRunIs}"
                        Command="{Binding DismissActivityCommand}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- ═══ Prompt overlay ═══ -->
    <Grid Visibility="{Binding IsPromptVisible, Converter={StaticResource BoolToVisibilityConverter}}"
          KeyboardNavigation.TabNavigation="Cycle">
      <Border Background="{DynamicResource OverlayBrush}">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsPromptVisible}" Value="True">
                <DataTrigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       From="0" To="1" Duration="{StaticResource MotionMedDuration}">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.EnterActions>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>
      <Grid Margin="64">
        <Border x:Name="PromptDialogRoot"
                Width="540"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="30"
                AutomationProperties.AutomationId="PromptDialogRoot"
                AutomationProperties.Name="{services:Loc Ui_DecisionPrompt}"
                AutomationProperties.HelpText="{services:Loc Ui_ConfirmsAnImportantLibreSpotActionBeforeItRuns}"
                Style="{StaticResource PromptCardStyle}">
          <StackPanel>
            <TextBlock FontWeight="SemiBold"
                       FontSize="11">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                  <Setter Property="Text" Value="{x:Static props:Strings.PromptActionConfirm}" />
                  <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsPromptDestructive}" Value="True">
                      <Setter Property="Text" Value="{x:Static props:Strings.PromptActionReset}" />
                      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="{Binding PromptTitle}" Style="{StaticResource SectionTitleTextStyle}" FontSize="22" />
            <TextBlock Text="{Binding PromptBody}" Style="{StaticResource BodyTextStyle}" Margin="0,12,0,0" />
            <Border Height="1"
                    Background="{DynamicResource StrokeSoftBrush}"
                    Margin="0,18,0,16" />
            <TextBlock Text="{Binding PromptSummaryTitle}">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsPromptDestructive}" Value="True">
                      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding PromptSummaryBody}"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
              <Button Content="{Binding PromptCancelText}"
                      x:Name="PromptCancelButton"
                      MinWidth="160"
                      Height="42"
                      Padding="18,0"
                      Margin="0,0,10,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      AutomationProperties.AutomationId="PromptCancelButton"
                      AutomationProperties.Name="{Binding PromptCancelText}"
                      IsCancel="True"
                      Command="{Binding CancelPromptCommand}" />
              <Button MinWidth="200"
                      x:Name="PromptConfirmButton"
                      Height="42"
                      Padding="18,0"
                      Content="{Binding PromptConfirmText}"
                      AutomationProperties.AutomationId="PromptConfirmButton"
                      AutomationProperties.Name="{Binding PromptConfirmText}"
                      IsDefault="{Binding IsPromptConfirmDefault}"
                      Command="{Binding ConfirmPromptCommand}">
                <Button.Style>
                  <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsPromptDestructive}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource DangerFillBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextOnDangerBrush}" />
                        <Setter Property="Tag" Value="{DynamicResource DangerHoverTintBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Button.Style>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <ui:SnackbarPresenter x:Name="CompletionSnackbarPresenter"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,28,28"
                          Panel.ZIndex="100"
                          AutomationProperties.Name="{services:Loc Ui_CompletionNotifications}" />
  </Grid>
</Window>
