                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Path Width="23"
                      Height="23"
                      Stretch="Uniform"
                      Data="M 12 2 L 21 6 V 12 C 21 17 17.5 20 12 22 C 6.5 20 3 17 3 12 V 6 Z M 8 12 L 11 15 L 16 9"
