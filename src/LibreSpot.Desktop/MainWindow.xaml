                    </Border.Style>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding ProfileStatusLine}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource MutedTextBrush}" />
                </Grid>
              </StackPanel>
            </Border>

            <StackPanel>
              <StackPanel.Style>
                <Style TargetType="StackPanel">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding HasCriticalHealthIssues}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding HasWarningHealthIssues}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </StackPanel.Style>
              <TextBlock Text="{Binding HealthIssueSummary}"
                         Style="{StaticResource SectionEyebrowTextStyle}"
                         Margin="0,20,0,8" />

              <StackPanel Visibility="{Binding HasCriticalHealthIssues, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Static props:Strings.SeverityCritical}"
                           Style="{StaticResource LabelTextStyle}"
                           Foreground="{DynamicResource DangerBrush}"
                           Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding CriticalHealthIssues}"
                              ItemTemplate="{StaticResource HealthIssueTemplate}" />
              </StackPanel>

              <StackPanel Visibility="{Binding HasWarningHealthIssues, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Static props:Strings.SeverityWarningsLabel}"
                           Style="{StaticResource LabelTextStyle}"
                           Foreground="{DynamicResource WarningBrush}"
                           Margin="0,4,0,8" />
                <ItemsControl ItemsSource="{Binding WarningHealthIssues}"
                              ItemTemplate="{StaticResource HealthIssueTemplate}" />
              </StackPanel>

            </StackPanel>

            <TextBlock Text="{x:Static props:Strings.NextStepLabel}" Style="{StaticResource SectionEyebrowTextStyle}" Margin="0,20,0,8" Visibility="Collapsed" />
            <TextBlock Text="{Binding WorkspaceRecommendationTitle}"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="{StaticResource HeadingFont}"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Visibility="Collapsed" />
            <TextBlock Text="{Binding WorkspaceRecommendationBrief}"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,6,0,0"
                       Visibility="Collapsed" />
            <TextBlock Text="{Binding RecommendedRunDuration}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,10,0,0"
                       Visibility="Collapsed" />

            <TextBlock Text="{x:Static props:Strings.ProfileRecoveryLabel}"
                       Style="{StaticResource SectionEyebrowTextStyle}"
                       Margin="0,22,0,10"
                       Visibility="{Binding HasConfigurationRecoveryNotice, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Border Style="{StaticResource SubtleCardStyle}"
                    Background="{DynamicResource WarningSoftBrush}"
                    BorderBrush="{DynamicResource WarningRingBrush}"
                    Visibility="{Binding HasConfigurationRecoveryNotice, Converter={StaticResource BoolToVisibilityConverter}}">
              <StackPanel>
                <TextBlock Text="{Binding ConfigurationRecoveryTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontFamily="{StaticResource HeadingFont}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ConfigurationRecoveryDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,6,0,0" />
                <Button Content="{x:Static props:Strings.ButtonOpenLibreSpotFolder}"
                        Height="40"
                        Margin="0,14,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonOpenLibreSpotFolder}"
                        AutomationProperties.HelpText="{x:Static props:Strings.ButtonOpenLibreSpotFolderHint}"
                        Command="{Binding OpenLibreSpotFolderCommand}" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom" Margin="0,24,0,0">
            <Border Style="{StaticResource SubtleCardStyle}"
                    Background="{DynamicResource Surface1Brush}"
                    BorderBrush="{DynamicResource StrokeBrush}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Ellipse Width="12"
                         Height="12"
                         Fill="{DynamicResource AccentBrush}"
                         VerticalAlignment="Top"
                         Margin="0,4,12,0" />
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding ShellUpdateStatusTitle}"
                             Foreground="{DynamicResource TextBrush}"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ShellUpdateStatusDetail}"
                             Style="{StaticResource CaptionTextStyle}"
                             Margin="0,4,0,0" />
                </StackPanel>
              </Grid>
            </Border>
            <Button Content="{x:Static props:Strings.ButtonRefreshEnvironment}"
                    Style="{StaticResource GhostButtonStyle}"
                    Height="40"
                    Visibility="Collapsed"
                    ToolTip="{x:Static props:Strings.ButtonRefreshEnvironmentHint}"
                    AutomationProperties.Name="{x:Static props:Strings.ButtonRefreshEnvironment}"
                    AutomationProperties.HelpText="{x:Static props:Strings.ButtonRefreshEnvironmentHint}"
                    Command="{Binding RefreshSnapshotCommand}" />
            <Border Margin="0,12,0,0">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
                  <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                  <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSnapshotStale}" Value="True">
                      <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="{x:Static props:Strings.StackSnapshotLabel}">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSnapshotStale}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding SnapshotFreshnessTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding SnapshotFreshnessDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
              </StackPanel>
            </Border>
            <TextBlock Text="{x:Static props:Strings.StackSnapshotHint}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       TextAlignment="Left"
                       Margin="0,10,0,0"
                       Visibility="Collapsed" />
          </StackPanel>
        </DockPanel>
        </ScrollViewer>
      </Border>

      <!-- ═══ Main content ═══ -->
      <Border Grid.Column="2"
              Style="{StaticResource SurfaceCardStyle}"
              Margin="0,58,0,38"
              Padding="16,18,16,14">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,24,0">
              <TextBlock Text="{Binding WorkspaceHeroEyebrow}"
                         Style="{StaticResource SectionEyebrowTextStyle}"
                         Foreground="{DynamicResource AccentBrush}"
                         Visibility="Collapsed" />
              <TextBlock Text="{Binding WorkspaceHeroTitle}"
                         Style="{StaticResource HeadlineTextStyle}"
                         FontSize="24"
                         LineHeight="32" />
              <TextBlock Text="{Binding WorkspaceHeroBody}"
                         Style="{StaticResource CaptionTextStyle}"
                         Margin="0,6,0,0"
                         MaxWidth="760"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
              <WrapPanel HorizontalAlignment="Right"
                         Margin="0,0,0,12"
                         Visibility="Collapsed">
                <Button Content="{Binding ShellTopThemeLabel}"
                        Height="36"
                        MinWidth="84"
                        Padding="14,0"
                        Margin="0,0,8,0"
                        Style="{StaticResource GhostButtonStyle}"
                        AutomationProperties.Name="{services:Loc Ui_OpenSpicetifyThemeCatalog}"
                        Command="{Binding OpenThemeCatalogCommand}" />
                <ComboBox ItemsSource="{Binding LocalizationOptions}"
                          SelectedItem="{Binding SelectedLocalizationOption, Mode=TwoWay}"
                          Width="128"
                          Height="36"
                          Margin="0,0,8,0"
                          Style="{StaticResource ComboBoxStylePremium}"
                          AutomationProperties.Name="{services:Loc LanguageLabel}"
                          AutomationProperties.HelpText="{services:Loc LanguageHelpText}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding DisplayName}"
                                 TextTrimming="CharacterEllipsis"
                                 TextWrapping="NoWrap" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="{Binding ShellTopSettingsLabel}"
                        Height="36"
                        MinWidth="88"
                        Padding="14,0"
                        Style="{StaticResource GhostButtonStyle}"
                        AutomationProperties.Name="{services:Loc Ui_CustomSettings}"
                        Command="{Binding ShowCustomWorkspaceCommand}" />
              </WrapPanel>
              <Button Content="{x:Static props:Strings.ButtonRunRecommendedSetup}"
                      Height="52"
                      MinWidth="280"
                      Padding="18,0"
                      Margin="0,8,0,8"
                      FontSize="14.5"
                      Style="{StaticResource PrimaryButtonStyle}"
                      AutomationProperties.AutomationId="RunRecommendedSetupButton"
                      AutomationProperties.Name="{x:Static props:Strings.ButtonRunRecommendedSetup}"
                      AutomationProperties.HelpText="{services:Loc Ui_RunsLibreSpotSMostReliableInstallPathWith}"
                      Command="{Binding ApplyRecommendedCommand}" />
              <TextBlock Text="{Binding SessionAccessTitle}"
                         Style="{StaticResource LabelTextStyle}"
                         TextAlignment="Right"
                         Visibility="Collapsed" />
              <TextBlock Text="{Binding SessionAccessDetail}"
                         Style="{StaticResource CaptionTextStyle}"
                         TextAlignment="Right"
                         TextWrapping="Wrap"
                         Width="260"
                         Margin="0,6,0,0"
                         Visibility="Collapsed" />
              <Button Content="{services:Loc Ui_RelaunchAsAdministrator}"
                      Height="40"
                      Margin="0,14,0,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      AutomationProperties.Name="{services:Loc Ui_RelaunchLibreSpotAsAdministrator}"
                      AutomationProperties.HelpText="{services:Loc Ui_RestartsLibreSpotWithAdministratorAccessBeforeApplyingChanges}"
                      Visibility="Collapsed"
                      Command="{Binding RelaunchAsAdministratorCommand}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Height="1"
                    Background="{DynamicResource StrokeSoftBrush}"
                    Margin="0,18,0,0" />
          </Grid>

          <Border Grid.Row="1"
                  Background="{DynamicResource Surface1Brush}"
                  BorderBrush="{DynamicResource StrokeBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Margin="0,0,0,14"
                  ClipToBounds="True">
            <ItemsControl ItemsSource="{Binding ShellSummaryItems}"
                          ItemTemplate="{StaticResource ShellSummaryItemTemplate}"
                          AutomationProperties.Name="{x:Static props:Strings.EnvironmentLabel}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </Border>

          <!-- Workspace tabs -->
          <TabControl Grid.Row="2"
                      Style="{StaticResource WorkspaceTabControlStyle}"
                      MaxHeight="400"
                      SelectedIndex="{Binding SelectedWorkspaceIndex}">
            <TabControl.ItemContainerStyle>
              <Style TargetType="TabItem" BasedOn="{StaticResource WorkspaceTabItemStyle}" />
            </TabControl.ItemContainerStyle>

            <!-- ═══ Recommended (condensed: big apply button first, everything else below) ═══ -->
            <TabItem Header="{x:Static props:Strings.ModeRecommendedTitle}"
                     AutomationProperties.AutomationId="WorkspaceTabRecommended">
              <ScrollViewer VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                <ContentControl Focusable="True"
                                AutomationProperties.AutomationId="RecommendedWorkspace"
                                AutomationProperties.Name="{services:Loc Ui_RecommendedWorkspace}">
                <StackPanel Margin="0,8,0,0">
                  <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="0.9*" />
                      <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SubtleCardStyle}"
                            Padding="16"
                            Margin="0,0,8,0">
                      <StackPanel>
                        <TextBlock Text="{Binding ShellLocalEnvironmentTitle}"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   FontSize="16" />
                        <Border Height="1"
                                Background="{DynamicResource StrokeSoftBrush}"
                                Margin="0,10,0,14" />
                        <ItemsControl ItemsSource="{Binding ShellEnvironmentRows}"
                                      ItemTemplate="{StaticResource ShellEnvironmentRowTemplate}" />
                        <Button Content="{Binding ShellEnvironmentReportLinkText}"
                                Height="34"
                                Margin="0,6,0,0"
                                Padding="0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GhostButtonStyle}"
                                Foreground="{DynamicResource AccentBrush}"
                                AutomationProperties.Name="{Binding ShellEnvironmentReportLinkText}"
                                Command="{Binding RefreshSnapshotCommand}" />
                      </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource SubtleCardStyle}"
                            Padding="16"
                            Margin="8,0,0,0">
                      <StackPanel>
                        <TextBlock Text="{Binding ShellDependenciesTitle}"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   FontSize="16" />
                        <Grid Margin="0,10,0,0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.25*" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="42" />
                          </Grid.ColumnDefinitions>
                          <Border Grid.ColumnSpan="4"
                                  Height="1"
                                  Background="{DynamicResource StrokeSoftBrush}"
                                  VerticalAlignment="Bottom" />
                          <TextBlock Text="{Binding ShellDependencyComponentHeader}" Style="{StaticResource LabelTextStyle}" />
                          <TextBlock Grid.Column="1" Text="{Binding ShellDependencyInstalledHeader}" Style="{StaticResource LabelTextStyle}" Margin="10,0" />
                          <TextBlock Grid.Column="2" Text="{Binding ShellDependencyRecommendedHeader}" Style="{StaticResource LabelTextStyle}" Margin="10,0" />
                          <TextBlock Grid.Column="3" Text="{Binding ShellDependencyStatusHeader}" Style="{StaticResource LabelTextStyle}" TextAlignment="Center" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ShellDependencyRows}"
                                      ItemTemplate="{StaticResource ShellDependencyRowTemplate}" />
                        <TextBlock Text="{Binding ShellDependenciesSummaryText}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,8,0,0" />
                      </StackPanel>
                    </Border>
                  </Grid>
                </StackPanel>
                </ContentControl>
              </ScrollViewer>
            </TabItem>

            <!-- ═══ Custom ═══ -->
            <TabItem Header="{x:Static props:Strings.ModeCustomTitle}"
                     AutomationProperties.AutomationId="WorkspaceTabCustom">
              <Grid AutomationProperties.AutomationId="CustomWorkspace"
                    AutomationProperties.Name="{services:Loc Ui_CustomWorkspace}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Disabled"
                               AutomationProperties.AutomationId="CustomSettingsEditor"
                               AutomationProperties.Name="{services:Loc Ui_CustomSettingsEditor}"
                               Margin="0,0,22,0">
                  <StackPanel>
                    <TextBlock Text="{x:Static props:Strings.SearchPlaceholder}"
                               Style="{StaticResource LabelTextStyle}" />
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBox Text="{Binding SettingsSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource TextBoxStylePremium}"
                               Height="42"
                               AutomationProperties.AutomationId="SettingsSearchBox"
                               AutomationProperties.Name="{x:Static props:Strings.SearchPlaceholder}"
                               AutomationProperties.HelpText="{x:Static props:Strings.SearchHelpText}" />
                      <Button Grid.Column="1"
                              Content="{x:Static props:Strings.ButtonClearSearch}"
                              Height="42"
                              MinWidth="84"
                              Margin="10,0,0,0"
                              Padding="18,0"
                              Style="{StaticResource SecondaryButtonStyle}"
                              Visibility="{Binding HasSettingsSearchText, Converter={StaticResource BoolToVisibilityConverter}}"
                              Command="{Binding ClearSettingsSearchCommand}"
                              AutomationProperties.AutomationId="SettingsSearchClearButton"
                              AutomationProperties.Name="{x:Static props:Strings.ButtonClearSearchName}" />
                    </Grid>
                    <TextBlock Text="{Binding CustomSearchSummary}"
                               Style="{StaticResource CaptionTextStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,10,0,18"
                               MaxWidth="760"
                               TextWrapping="Wrap" />

                    <Border Style="{StaticResource SubtleCardStyle}"
                            Background="{DynamicResource Surface1Brush}"
                            Margin="0,0,0,18"
                            Visibility="{Binding ShowCustomSearchEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="4"
                                Height="38"
                                CornerRadius="2"
                                Background="{DynamicResource StrokeStrongBrush}"
                                Margin="0,2,12,0"
                                VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="{x:Static props:Strings.SearchNoResults}"
                                     Style="{StaticResource EmptyStateTitleTextStyle}" />
                          <TextBlock Text="{x:Static props:Strings.SearchNoResultsHint}"
                                     Style="{StaticResource EmptyStateBodyTextStyle}"
                                     Margin="0,6,0,0" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <Border Style="{StaticResource MinimalSectionStyle}"
                            Visibility="{Binding HasVisibleInstallOptions, Converter={StaticResource BoolToVisibilityConverter}}">
                      <StackPanel>
                        <TextBlock Text="{x:Static props:Strings.InstallPostureSection}" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="{x:Static props:Strings.InstallPostureDescription}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,6,0,14" />
                        <ItemsControl ItemsSource="{Binding InstallOptions}" ItemTemplate="{StaticResource OptionTemplate}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                        </ItemsControl>
                      </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MinimalSectionStyle}"
                            Visibility="{Binding HasVisibleAppearanceSettings, Converter={StaticResource BoolToVisibilityConverter}}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="1.15*" />
                          <ColumnDefinition Width="0.85*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                          <TextBlock Text="{x:Static props:Strings.AppearanceSection}" Style="{StaticResource SectionTitleTextStyle}" />
                          <TextBlock Text="{x:Static props:Strings.AppearanceDescription}"
                                     Style="{StaticResource BodyTextStyle}"
                                     Margin="0,6,0,16" />

                          <TextBlock Text="{x:Static props:Strings.ThemePackLabel}" Style="{StaticResource LabelTextStyle}" />
                          <Grid Margin="0,6,0,10">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ThemeSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStylePremium}"
                                     Height="42"
                                     AutomationProperties.Name="{x:Static props:Strings.ThemeGallerySearchName}"
                                     AutomationProperties.HelpText="{x:Static props:Strings.ThemeGallerySearchHint}" />
                            <Button Grid.Column="1"
                                    Content="{x:Static props:Strings.ButtonClearSearch}"
                                    Height="42"
                                    MinWidth="84"
                                    Margin="10,0,0,0"
                                    Padding="18,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Visibility="{Binding HasThemeSearchText, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding ClearThemeSearchCommand}"
                                    AutomationProperties.Name="{x:Static props:Strings.ButtonClearSearchName}" />
                          </Grid>

                          <ListBox ItemsSource="{Binding FilteredThemeGalleryItems}"
                                   SelectedItem="{Binding SelectedThemeGalleryItem, Mode=TwoWay}"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   Padding="0"
                                   MaxHeight="340"
                                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                                   KeyboardNavigation.DirectionalNavigation="Contained"
                                   AutomationProperties.Name="{x:Static props:Strings.ThemePackLabel}"
                                   AutomationProperties.HelpText="{x:Static props:Strings.ThemePackHint}"
                                   Margin="0,0,0,14">
                            <ListBox.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel />
                              </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                              <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,0,10,10" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <!-- Constant thickness: the keyboard focus ring swaps brush
                                     only, so focus never shifts layout. -->
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                                <Setter Property="AutomationProperties.HelpText" Value="{Binding AutomationHelpText}" />
                                <Style.Triggers>
                                  <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
                                  </Trigger>
                                </Style.Triggers>
                              </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                              <DataTemplate>
                                <Border Width="246"
                                        MinHeight="152"
                                        Padding="12"
                                        Background="{DynamicResource Surface1Brush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                  <Border.Style>
                                    <Style TargetType="Border">
                                      <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
                                      <Style.Triggers>
                                        <!-- Hover affordance; selection accent overrides it. -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                          <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}" />
                                          <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                          <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </Border.Style>
                                  <StackPanel>
                                    <Grid Height="46" ClipToBounds="True">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                      </Grid.ColumnDefinitions>
                                      <Border Grid.Column="0" Background="{Binding SwatchA}" CornerRadius="6,0,0,6" />
                                      <Border Grid.Column="1" Background="{Binding SwatchB}" />
                                      <Border Grid.Column="2" Background="{Binding SwatchC}" CornerRadius="0,6,6,0" />
                                    </Grid>
                                    <StackPanel Margin="0,10,0,0">
                                      <TextBlock Text="{Binding Label}"
                                                 Foreground="{DynamicResource TextBrush}"
                                                 FontWeight="SemiBold"
                                                 TextWrapping="Wrap" />
                                      <Border Style="{StaticResource MicroBadgeStyle}"
                                              HorizontalAlignment="Left"
                                              Margin="0,7,0,0">
                                        <TextBlock Text="{Binding SourceBadge}"
                                                   Style="{StaticResource MicroBadgeTextStyle}" />
                                      </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding SchemeCountText}"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding SchemePreview}"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               MaxHeight="36"
                                               Margin="0,4,0,0" />
                                    <Border Style="{StaticResource MicroBadgeStyle}"
                                            Margin="0,8,0,0"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding HasJsBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                      <TextBlock Text="{Binding JsBadge}"
                                                 Style="{StaticResource MicroBadgeTextStyle}" />
                                    </Border>
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>

                          <TextBlock Text="{Binding ThemeGalleryEmptyText}"
                                     Style="{StaticResource CaptionTextStyle}"
                                     Foreground="{DynamicResource WarningBrush}"
                                     Visibility="{Binding ShowThemeGalleryEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                                     Margin="0,0,0,14" />

                          <TextBlock Text="{x:Static props:Strings.ColorSchemeLabel}" Style="{StaticResource LabelTextStyle}" />
                          <ListBox ItemsSource="{Binding SchemeOptions}"
                                   SelectedItem="{Binding SelectedScheme, Mode=TwoWay}"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   Padding="0"
                                   IsEnabled="{Binding IsThemeSchemeAvailable}"
                                   AutomationProperties.Name="{x:Static props:Strings.ColorSchemeLabel}"
                                   AutomationProperties.HelpText="{Binding ThemeSchemeHint}"
                                   Margin="0,6,0,6">
                            <ListBox.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel />
                              </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                              <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,0,8,8" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
