<Window x:Class="LibreSpot.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:LibreSpot.Desktop.Controls"
        xmlns:avalon="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
        xmlns:models="clr-namespace:LibreSpot.Desktop.Models"
        xmlns:viewModels="clr-namespace:LibreSpot.Desktop.ViewModels"
        xmlns:props="clr-namespace:LibreSpot.Desktop.Properties"
        xmlns:services="clr-namespace:LibreSpot.Desktop.Services"
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        mc:Ignorable="d"
        Title="{services:Loc AppTitle}"
        Width="1440"
        Height="920"
        MinWidth="1200"
        MinHeight="820"
        Icon="pack://application:,,,/Assets/LibreSpot.ico"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource CanvasBrush}"
        Style="{StaticResource WindowChromeStyle}">
  <Window.InputBindings>
    <KeyBinding Key="Escape" Command="{Binding EscapeCommand}" />
    <KeyBinding Key="F5" Command="{Binding RefreshSnapshotCommand}" />
  </Window.InputBindings>

  <Window.TaskbarItemInfo>
    <!-- Mirror run state onto the taskbar icon so users see progress at a glance
         even when LibreSpot is minimized during a patch run. -->
    <TaskbarItemInfo ProgressState="{Binding TaskbarProgressState}"
                     ProgressValue="{Binding TaskbarProgressFraction}">
      <TaskbarItemInfo.ThumbButtonInfos>
        <ThumbButtonInfo Description="{services:Loc ModeRecommendedDescription}"
                         Command="{Binding ShowRecommendedWorkspaceCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
        <ThumbButtonInfo Description="{services:Loc Ui_CustomSettings}"
                         Command="{Binding ShowCustomWorkspaceCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
        <ThumbButtonInfo Description="{services:Loc ModeMaintenanceTitle}"
                         Command="{Binding ShowMaintenanceWorkspaceCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
        <ThumbButtonInfo Description="{services:Loc Ui_ImportProfile}"
                         Command="{Binding ImportProfileCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
        <ThumbButtonInfo Description="{services:Loc ButtonOpenLibreSpotFolder}"
                         Command="{Binding OpenLibreSpotFolderCommand}"
                         ImageSource="pack://application:,,,/Assets/LibreSpot.ico" />
      </TaskbarItemInfo.ThumbButtonInfos>
    </TaskbarItemInfo>
  </Window.TaskbarItemInfo>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <Style x:Key="StatusMarkerStyle" TargetType="Border">
      <Setter Property="Width" Value="4" />
      <Setter Property="Height" Value="14" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="Margin" Value="0,2,10,0" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="MinimalSectionStyle" TargetType="Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="0,0,0,18" />
      <Setter Property="Margin" Value="0,0,0,18" />
    </Style>

    <DataTemplate DataType="{x:Type viewModels:HealthIssueActionViewModel}" x:Key="HealthIssueActionTemplate">
      <Button Content="{Binding ButtonText}"
              Command="{Binding Command}"
              ToolTip="{Binding Description}"
              AutomationProperties.Name="{Binding ButtonText}"
              AutomationProperties.HelpText="{Binding Description}"
              MinWidth="0"
              Height="34"
              Padding="12,0"
              Margin="0,0,8,8">
        <Button.Style>
          <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="FontSize" Value="12" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Button.Style>
      </Button>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:HealthIssueViewModel}" x:Key="HealthIssueTemplate">
      <Border Margin="0,0,0,8">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding Severity}" Value="critical">
                <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding Severity}" Value="warning">
                <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Name}"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="12.5"
                       TextWrapping="Wrap"
                       Margin="0,0,10,0" />
            <TextBlock Grid.Column="1"
                       Text="{Binding Status}"
                       TextAlignment="Right">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                  <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Severity}" Value="critical">
                      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Severity}" Value="warning">
                      <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>
          <TextBlock Text="{Binding Evidence}"
                     Style="{StaticResource CaptionTextStyle}"
                     Margin="0,6,0,0" />
          <ItemsControl ItemsSource="{Binding Actions}"
                        ItemTemplate="{StaticResource HealthIssueActionTemplate}"
                        Margin="0,10,0,0"
                        Visibility="{Binding HasActions, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
          <TextBlock Text="{Binding RecommendedActionText}"
                     Style="{StaticResource CaptionTextStyle}"
                     Foreground="{DynamicResource MutedTextBrush}"
                     Margin="0,6,0,0"
                     Visibility="{Binding ShowRecommendedActionText, Converter={StaticResource BoolToVisibilityConverter}}" />
          <TextBlock Text="{Binding Path}"
                     Style="{StaticResource CaptionTextStyle}"
                     Foreground="{DynamicResource SubtleTextBrush}"
                     Margin="0,6,0,0"
                     Visibility="{Binding HasPath, Converter={StaticResource BoolToVisibilityConverter}}" />
          <TextBlock Text="{Binding LastChangedDisplay}"
                     Style="{StaticResource CaptionTextStyle}"
                     Foreground="{DynamicResource SubtleTextBrush}"
                     Margin="0,4,0,0"
                     Visibility="{Binding HasLastChanged, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:OptionToggleViewModel}" x:Key="OptionTemplate">
      <CheckBox Style="{StaticResource SettingCheckBoxStyle}"
                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                AutomationProperties.Name="{Binding Title}"
                AutomationProperties.HelpText="{Binding Description}"
                ToolTip="{Binding Description}"
                Margin="0,0,10,10">
        <StackPanel>
          <TextBlock Text="{Binding Title}"
                     Foreground="{DynamicResource TextBrush}"
                     FontWeight="SemiBold"
                     FontSize="13.5"
                     LineHeight="18"
                     TextWrapping="Wrap" />
          <Border MinWidth="86"
                  HorizontalAlignment="Left"
                  Margin="0,7,0,8">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                      <Setter Property="Background" Value="{DynamicResource AccentMistBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
                    </DataTrigger>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource MicroBadgeTextStyle}">
                    <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusOptional}" />
                    <Style.Triggers>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusRecommended}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="False" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusAdded}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusRemoved}" />
                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
          </Border>
          <TextBlock Text="{Binding Description}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </CheckBox>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:ExtensionToggleViewModel}" x:Key="ExtensionTemplate">
      <CheckBox Style="{StaticResource SettingCheckBoxStyle}"
                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                AutomationProperties.Name="{Binding Title}"
                AutomationProperties.HelpText="{Binding Description}"
                ToolTip="{Binding Description}"
                Margin="0,0,10,10">
        <StackPanel>
          <TextBlock Text="{Binding Title}"
                     Foreground="{DynamicResource TextBrush}"
                     FontWeight="SemiBold"
                     FontSize="13.5"
                     LineHeight="18"
                     TextWrapping="Wrap" />
          <Border MinWidth="76"
                  HorizontalAlignment="Left"
                  Margin="0,7,0,8">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                      <Setter Property="Background" Value="{DynamicResource AccentMistBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
                    </DataTrigger>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource MicroBadgeTextStyle}">
                    <Setter Property="Text" Value="{x:Static props:Strings.ExtensionStatusAvailable}" />
                    <Style.Triggers>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.ExtensionStatusDefault}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="False" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusAdded}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsRecommendedDefault}" Value="True" />
                          <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="{x:Static props:Strings.OptionStatusRemoved}" />
                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
          </Border>
          <TextBlock Text="{Binding Description}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </CheckBox>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:LocalProfileCardViewModel}" x:Key="LocalProfileTemplate">
      <Border Margin="0,0,0,8">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsActive}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Background" Value="{DynamicResource AccentMistBrush}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Width="4"
                  CornerRadius="2"
                  Margin="0,2,12,0"
                  VerticalAlignment="Stretch">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding StateTone}" Value="active">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding StateTone}" Value="template">
                    <Setter Property="Background" Value="{DynamicResource InfoBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
          </Border>
          <StackPanel Grid.Column="1">
            <TextBlock Text="{Binding Name}"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="13.5"
                       TextWrapping="Wrap"
                       LineHeight="18" />
            <WrapPanel Margin="0,7,0,0">
              <Border Margin="0,0,6,6">
                <Border.Style>
                  <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource AccentMistBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Text="{Binding StateBadge}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
              <Border Margin="0,0,6,6">
                <Border.Style>
                  <Style TargetType="Border" BasedOn="{StaticResource MicroBadgeStyle}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Text="{Binding KindBadge}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
              <Border Margin="0,0,6,6"
                      Style="{StaticResource MicroBadgeStyle}">
                <TextBlock Text="{Binding CapabilityText}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
            </WrapPanel>
            <TextBlock Text="{Binding Description}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,2,0,0"
                       TextTrimming="CharacterEllipsis"
                       Visibility="{Binding HasDescription, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock Text="{Binding UpdatedText}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       Margin="0,6,0,0" />
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:MaintenanceActionCardViewModel}" x:Key="MaintenanceTemplate">
      <Border Margin="0,0,0,12"
              Visibility="{Binding IsRelevant, Converter={StaticResource BoolToVisibilityConverter}}">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
            <Setter Property="Padding" Value="16" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Margin="0,0,18,0">
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="14"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding Description}"
                       Style="{StaticResource BodyTextStyle}"
                       Margin="0,6,0,0" />
            <TextBlock Margin="0,10,0,0">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                  <Setter Property="Text" Value="{x:Static props:Strings.MaintenanceCardDefaultDetail}" />
                  <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                      <Setter Property="Text" Value="{x:Static props:Strings.MaintenanceCardDestructiveDetail}" />
                      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>

          <Button Grid.Column="1"
                  MinWidth="150"
                  Height="42"
                  Padding="16,0"
                  Content="{Binding ButtonText}"
                  AutomationProperties.AutomationId="{Binding AutomationId}"
                  AutomationProperties.Name="{Binding ButtonText}"
                  AutomationProperties.HelpText="{Binding Description}"
                  Command="{Binding Command}">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:SupportBundleCategoryViewModel}" x:Key="SupportBundleCategoryTemplate">
      <CheckBox Style="{StaticResource SettingCheckBoxStyle}"
                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                AutomationProperties.Name="{Binding Title}"
                AutomationProperties.HelpText="{Binding Detail}"
                ToolTip="{Binding Detail}"
                Margin="0,0,10,10">
        <StackPanel>
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,0,10,0" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <Border Style="{StaticResource MicroBadgeStyle}" Margin="0,0,6,0">
                <TextBlock Text="{Binding FileCountText}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
              <Border Style="{StaticResource MicroBadgeStyle}">
                <TextBlock Text="{Binding EstimatedSizeText}"
                           Style="{StaticResource MicroBadgeTextStyle}" />
              </Border>
            </StackPanel>
          </Grid>
          <TextBlock Text="{Binding Detail}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </CheckBox>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:SelectionInsightViewModel}" x:Key="SelectionInsightTemplate">
      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Width="4"
                Height="14"
                CornerRadius="2"
                Margin="0,3,10,0"
                VerticalAlignment="Top">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding Tone}" Value="accent">
                  <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="warning">
                  <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
        </Border>
        <StackPanel Grid.Column="1">
          <TextBlock Text="{Binding Title}"
                     FontWeight="SemiBold"
                     FontSize="12.5"
                     Margin="0,0,0,4">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Tone}" Value="accent">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Tone}" Value="warning">
                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <TextBlock Text="{Binding Detail}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="SelectionBadgeTemplate">
      <Border Style="{StaticResource MicroBadgeStyle}"
              Background="{DynamicResource Surface3Brush}"
              BorderBrush="{DynamicResource StrokeBrush}"
              Margin="0,0,8,8">
        <TextBlock Text="{Binding}"
                   Style="{StaticResource MicroBadgeTextStyle}"
                   Foreground="{DynamicResource TextBrush}" />
      </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:StatusDashboardItemViewModel}" x:Key="StatusDashboardItemTemplate">
      <Border Style="{StaticResource SubtleCardStyle}"
              Margin="0,0,10,10"
              AutomationProperties.Name="{Binding Label}"
              AutomationProperties.HelpText="{Binding Detail}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Width="4"
                  CornerRadius="2"
                  Margin="0,2,12,0"
                  VerticalAlignment="Stretch">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Tone}" Value="{x:Static models:HealthSeverity.Ready}">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Tone}" Value="{x:Static models:HealthSeverity.Warning}">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Tone}" Value="{x:Static models:HealthSeverity.Critical}">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
          </Border>
          <StackPanel Grid.Column="1">
            <TextBlock Text="{Binding Label}"
                       Style="{StaticResource LabelTextStyle}" />
            <TextBlock Text="{Binding Value}"
                       FontWeight="SemiBold"
                       FontSize="15"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Tone}" Value="{x:Static models:HealthSeverity.Warning}">
                      <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tone}" Value="{x:Static models:HealthSeverity.Critical}">
                      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding Detail}"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,6,0,0" />
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>

    <!--
      Overlay card style: fade + subtle scale-in when the bound IsVisible flag
      transitions False→True. DataTrigger EnterActions run on every transition,
      unlike EventTrigger RoutedEvent="Loaded" which fires only on first tree
      attachment — a Visibility toggle doesn't re-fire Loaded.
    -->
    <Style x:Key="ActivityCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
      <Setter Property="Background" Value="{DynamicResource PanelStrongBrush}" />
      <Setter Property="Effect" Value="{StaticResource OverlayShadow}" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsActivityVisible}" Value="True">
          <DataTrigger.EnterActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="{StaticResource MotionSlowDuration}">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                 From="0.97" To="1" Duration="{StaticResource MotionSlowDuration}">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                 From="0.97" To="1" Duration="{StaticResource MotionSlowDuration}">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="PromptCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
      <Setter Property="Background" Value="{DynamicResource PanelStrongBrush}" />
      <Setter Property="Effect" Value="{StaticResource OverlayShadow}" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsPromptVisible}" Value="True">
          <DataTrigger.EnterActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="{StaticResource MotionSlowDuration}">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                 From="0.97" To="1" Duration="{StaticResource MotionSlowDuration}">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                 From="0.97" To="1" Duration="{StaticResource MotionSlowDuration}">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Background="{DynamicResource CanvasBrush}">
    <Grid Margin="24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="312" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- ═══ Sidebar ═══ -->
      <Border Grid.Column="0"
              Background="{DynamicResource RailBrush}"
              BorderBrush="{DynamicResource StrokeSoftBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="False">
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="{services:Loc AppTitle}"
                       Style="{StaticResource SectionEyebrowTextStyle}"
                       Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Text="{services:Loc AppSubtitle}"
                       Style="{StaticResource RailTitleTextStyle}"
                       FontSize="21"
                       Margin="0,8,0,0" />
            <TextBlock Text="{services:Loc SidebarDescription}"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,10,0,0" />

            <TextBlock Text="{services:Loc LanguageLabel}"
                       Style="{StaticResource LabelTextStyle}"
                       Margin="0,18,0,6" />
            <ComboBox ItemsSource="{Binding LocalizationOptions}"
                      SelectedItem="{Binding SelectedLocalizationOption, Mode=TwoWay}"
                      DisplayMemberPath="DisplayName"
                      Height="38"
                      Style="{StaticResource ComboBoxStylePremium}"
                      AutomationProperties.Name="{services:Loc LanguageLabel}"
                      AutomationProperties.HelpText="{services:Loc LanguageHelpText}" />

            <Border Height="1"
                    Background="{DynamicResource StrokeSoftBrush}"
                    Margin="0,18,0,18" />

            <TextBlock Text="{x:Static props:Strings.EnvironmentLabel}" Style="{StaticResource SectionEyebrowTextStyle}" />
            <Border Style="{StaticResource MetricCardStyle}">
              <StackPanel>
                <TextBlock Text="{Binding Snapshot.StatusTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontFamily="{StaticResource HeadingFont}"
                           FontSize="17"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Snapshot.StatusDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,6,0,14" />

                <!-- Status rows -->
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border>
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource StatusMarkerStyle}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Snapshot.SpotifyInstalled}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding SpotifyStatusLine}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource MutedTextBrush}" />
                </Grid>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border>
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource StatusMarkerStyle}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Snapshot.SpicetifyInstalled}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding CustomizationStatusLine}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource MutedTextBrush}" />
                </Grid>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border>
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource StatusMarkerStyle}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Snapshot.MarketplaceReady}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding MarketplaceStatusLine}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource MutedTextBrush}" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border>
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource StatusMarkerStyle}">
                        <Style.Triggers>
                          <!-- Last matching trigger wins in WPF: the recovery-notice warning
                               must stay below SavedConfigExists so it overrides the green. -->
                          <DataTrigger Binding="{Binding Snapshot.SavedConfigExists}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding HasConfigurationRecoveryNotice}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding ProfileStatusLine}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource MutedTextBrush}" />
                </Grid>
              </StackPanel>
            </Border>

            <StackPanel>
              <StackPanel.Style>
                <Style TargetType="StackPanel">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding HasCriticalHealthIssues}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding HasWarningHealthIssues}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </StackPanel.Style>
              <TextBlock Text="{Binding HealthIssueSummary}"
                         Style="{StaticResource SectionEyebrowTextStyle}"
                         Margin="0,20,0,8" />

              <StackPanel Visibility="{Binding HasCriticalHealthIssues, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Static props:Strings.SeverityCritical}"
                           Style="{StaticResource LabelTextStyle}"
                           Foreground="{DynamicResource DangerBrush}"
                           Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding CriticalHealthIssues}"
                              ItemTemplate="{StaticResource HealthIssueTemplate}" />
              </StackPanel>

              <StackPanel Visibility="{Binding HasWarningHealthIssues, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Static props:Strings.SeverityWarningsLabel}"
                           Style="{StaticResource LabelTextStyle}"
                           Foreground="{DynamicResource WarningBrush}"
                           Margin="0,4,0,8" />
                <ItemsControl ItemsSource="{Binding WarningHealthIssues}"
                              ItemTemplate="{StaticResource HealthIssueTemplate}" />
              </StackPanel>

            </StackPanel>

            <TextBlock Text="{x:Static props:Strings.NextStepLabel}" Style="{StaticResource SectionEyebrowTextStyle}" Margin="0,20,0,8" />
            <TextBlock Text="{Binding WorkspaceRecommendationTitle}"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="{StaticResource HeadingFont}"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding WorkspaceRecommendationBrief}"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,6,0,0" />
            <TextBlock Text="{Binding RecommendedRunDuration}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,10,0,0" />

            <TextBlock Text="{x:Static props:Strings.ProfileRecoveryLabel}"
                       Style="{StaticResource SectionEyebrowTextStyle}"
                       Margin="0,22,0,10"
                       Visibility="{Binding HasConfigurationRecoveryNotice, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Border Style="{StaticResource SubtleCardStyle}"
                    Background="{DynamicResource WarningSoftBrush}"
                    BorderBrush="{DynamicResource WarningRingBrush}"
                    Visibility="{Binding HasConfigurationRecoveryNotice, Converter={StaticResource BoolToVisibilityConverter}}">
              <StackPanel>
                <TextBlock Text="{Binding ConfigurationRecoveryTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontFamily="{StaticResource HeadingFont}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ConfigurationRecoveryDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,6,0,0" />
                <Button Content="{x:Static props:Strings.ButtonOpenLibreSpotFolder}"
                        Height="40"
                        Margin="0,14,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonOpenLibreSpotFolder}"
                        AutomationProperties.HelpText="{x:Static props:Strings.ButtonOpenLibreSpotFolderHint}"
                        Command="{Binding OpenLibreSpotFolderCommand}" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom" Margin="0,24,0,0">
            <Button Content="{x:Static props:Strings.ButtonRefreshEnvironment}"
                    Style="{StaticResource GhostButtonStyle}"
                    Height="40"
                    ToolTip="{x:Static props:Strings.ButtonRefreshEnvironmentHint}"
                    AutomationProperties.Name="{x:Static props:Strings.ButtonRefreshEnvironment}"
                    AutomationProperties.HelpText="{x:Static props:Strings.ButtonRefreshEnvironmentHint}"
                    Command="{Binding RefreshSnapshotCommand}" />
            <Border Margin="0,12,0,0">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
                  <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                  <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSnapshotStale}" Value="True">
                      <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="{x:Static props:Strings.StackSnapshotLabel}">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSnapshotStale}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding SnapshotFreshnessTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding SnapshotFreshnessDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
              </StackPanel>
            </Border>
            <TextBlock Text="{x:Static props:Strings.StackSnapshotHint}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       TextAlignment="Left"
                       Margin="0,10,0,0" />
          </StackPanel>
        </DockPanel>
        </ScrollViewer>
      </Border>

      <!-- ═══ Main content ═══ -->
      <Border Grid.Column="1"
              Margin="22,0,0,0"
              Style="{StaticResource SurfaceCardStyle}"
              Padding="28">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,24,0">
              <TextBlock Text="{Binding WorkspaceHeroEyebrow}"
                         Style="{StaticResource SectionEyebrowTextStyle}"
                         Foreground="{DynamicResource AccentBrush}" />
              <TextBlock Text="{Binding WorkspaceHeroTitle}"
                         Style="{StaticResource HeadlineTextStyle}"
                         FontSize="28"
                         Margin="0,8,0,0" />
              <TextBlock Text="{Binding WorkspaceHeroBody}"
                         Style="{StaticResource CaptionTextStyle}"
                         Margin="0,10,0,0"
                         MaxWidth="760"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
              <TextBlock Text="{Binding SessionAccessTitle}"
                         Style="{StaticResource LabelTextStyle}"
                         TextAlignment="Right" />
              <TextBlock Text="{Binding SessionAccessDetail}"
                         Style="{StaticResource CaptionTextStyle}"
                         TextAlignment="Right"
                         TextWrapping="Wrap"
                         Width="260"
                         Margin="0,6,0,0" />
              <Button Content="{services:Loc Ui_RelaunchAsAdministrator}"
                      Height="40"
                      Margin="0,14,0,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      AutomationProperties.Name="{services:Loc Ui_RelaunchLibreSpotAsAdministrator}"
                      AutomationProperties.HelpText="{services:Loc Ui_RestartsLibreSpotWithAdministratorAccessBeforeApplyingChanges}"
                      Visibility="{Binding NeedsAdministratorRelaunch, Converter={StaticResource BoolToVisibilityConverter}}"
                      Command="{Binding RelaunchAsAdministratorCommand}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Height="1"
                    Background="{DynamicResource StrokeSoftBrush}"
                    Margin="0,18,0,0" />
          </Grid>

          <!-- Workspace tabs -->
          <TabControl Grid.Row="1"
                      Style="{StaticResource WorkspaceTabControlStyle}"
                      SelectedIndex="{Binding SelectedWorkspaceIndex}">
            <TabControl.ItemContainerStyle>
              <Style TargetType="TabItem" BasedOn="{StaticResource WorkspaceTabItemStyle}" />
            </TabControl.ItemContainerStyle>

            <!-- ═══ Recommended (condensed: big apply button first, everything else below) ═══ -->
            <TabItem Header="{x:Static props:Strings.ModeRecommendedTitle}"
                     AutomationProperties.AutomationId="WorkspaceTabRecommended">
              <ScrollViewer VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            AutomationProperties.AutomationId="RecommendedWorkspace"
                            AutomationProperties.Name="{services:Loc Ui_RecommendedWorkspace}">
                <StackPanel Margin="0,12,0,0">
                  <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="1.1*" />
                      <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,14,0">
                      <StackPanel>
                        <TextBlock Text="{x:Static props:Strings.ModeRecommendedDescription}"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   FontSize="22" />
                        <TextBlock Text="{Binding WorkspaceRecommendationDetail}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,8,0,0" />

                        <Button Height="58"
                                Margin="0,20,0,0"
                                FontSize="17"
                                Style="{StaticResource PrimaryButtonStyle}"
                                AutomationProperties.AutomationId="RunRecommendedSetupButton"
                                AutomationProperties.Name="{x:Static props:Strings.ButtonRunRecommendedSetup}"
                                AutomationProperties.HelpText="{services:Loc Ui_RunsLibreSpotSMostReliableInstallPathWith}"
                                Command="{Binding ApplyRecommendedCommand}">
                          <StackPanel Orientation="Horizontal">
                            <Path Width="22" Height="22"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"
                                  Stroke="{DynamicResource TextOnAccentBrush}"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 12 2 L 12 11 M 5 6 A 9 9 0 1 0 19 6" />
                            <TextBlock Text="{x:Static props:Strings.ButtonRunRecommendedSetup}" VerticalAlignment="Center" />
                          </StackPanel>
                        </Button>

                        <TextBlock Text="{Binding RecommendedRunDuration}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                      </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                      <TextBlock Text="{x:Static props:Strings.WhatIncludesLabel}"
                                 Style="{StaticResource SectionTitleTextStyle}"
                                 FontSize="17" />
                      <ItemsControl ItemsSource="{Binding RecommendedHighlights}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid Margin="0,0,0,10">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <Border Width="4"
                                      Height="14"
                                      CornerRadius="2"
                                      Background="{DynamicResource AccentBrush}"
                                      Margin="0,4,10,0"
                                      VerticalAlignment="Top" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding}"
                                         Style="{StaticResource CaptionTextStyle}"
                                         Foreground="{DynamicResource TextBrush}" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="{Binding RecommendedFollowUpText}"
                                 Style="{StaticResource CaptionTextStyle}"
                                 Foreground="{DynamicResource MutedTextBrush}"
                                 Margin="0,14,0,0"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>

                  <Border Height="1"
                          Background="{DynamicResource StrokeSoftBrush}"
                          Margin="0,0,0,16" />

                  <TextBlock Text="{x:Static props:Strings.RecommendedModeHint}"
                             Style="{StaticResource CaptionTextStyle}"
                             Foreground="{DynamicResource TextBrush}"
                             MaxWidth="780"
                             TextWrapping="Wrap" />
                </StackPanel>
              </ScrollViewer>
            </TabItem>

            <!-- ═══ Custom ═══ -->
            <TabItem Header="{x:Static props:Strings.ModeCustomTitle}"
                     AutomationProperties.AutomationId="WorkspaceTabCustom">
              <Grid AutomationProperties.AutomationId="CustomWorkspace"
                    AutomationProperties.Name="{services:Loc Ui_CustomWorkspace}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Disabled"
                               AutomationProperties.AutomationId="CustomSettingsEditor"
                               AutomationProperties.Name="{services:Loc Ui_CustomSettingsEditor}"
                               Margin="0,0,22,0">
                  <StackPanel>
                    <TextBlock Text="{x:Static props:Strings.SearchPlaceholder}"
                               Style="{StaticResource LabelTextStyle}" />
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBox Text="{Binding SettingsSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource TextBoxStylePremium}"
                               Height="42"
                               AutomationProperties.AutomationId="SettingsSearchBox"
                               AutomationProperties.Name="{x:Static props:Strings.SearchPlaceholder}"
                               AutomationProperties.HelpText="{x:Static props:Strings.SearchHelpText}" />
                      <Button Grid.Column="1"
                              Content="{x:Static props:Strings.ButtonClearSearch}"
                              Height="42"
                              MinWidth="84"
                              Margin="10,0,0,0"
                              Padding="18,0"
                              Style="{StaticResource SecondaryButtonStyle}"
                              Visibility="{Binding HasSettingsSearchText, Converter={StaticResource BoolToVisibilityConverter}}"
                              Command="{Binding ClearSettingsSearchCommand}"
                              AutomationProperties.AutomationId="SettingsSearchClearButton"
                              AutomationProperties.Name="{x:Static props:Strings.ButtonClearSearchName}" />
                    </Grid>
                    <TextBlock Text="{Binding CustomSearchSummary}"
                               Style="{StaticResource CaptionTextStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,10,0,18"
                               MaxWidth="760"
                               TextWrapping="Wrap" />

                    <Border Style="{StaticResource SubtleCardStyle}"
                            Background="{DynamicResource Surface1Brush}"
                            Margin="0,0,0,18"
                            Visibility="{Binding ShowCustomSearchEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="4"
                                Height="38"
                                CornerRadius="2"
                                Background="{DynamicResource StrokeStrongBrush}"
                                Margin="0,2,12,0"
                                VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="{x:Static props:Strings.SearchNoResults}"
                                     Style="{StaticResource EmptyStateTitleTextStyle}" />
                          <TextBlock Text="{x:Static props:Strings.SearchNoResultsHint}"
                                     Style="{StaticResource EmptyStateBodyTextStyle}"
                                     Margin="0,6,0,0" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <Border Style="{StaticResource MinimalSectionStyle}"
                            Visibility="{Binding HasVisibleInstallOptions, Converter={StaticResource BoolToVisibilityConverter}}">
                      <StackPanel>
                        <TextBlock Text="{x:Static props:Strings.InstallPostureSection}" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="{x:Static props:Strings.InstallPostureDescription}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,6,0,14" />
                        <ItemsControl ItemsSource="{Binding InstallOptions}" ItemTemplate="{StaticResource OptionTemplate}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                        </ItemsControl>
                      </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MinimalSectionStyle}"
                            Visibility="{Binding HasVisibleAppearanceSettings, Converter={StaticResource BoolToVisibilityConverter}}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="1.15*" />
                          <ColumnDefinition Width="0.85*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                          <TextBlock Text="{x:Static props:Strings.AppearanceSection}" Style="{StaticResource SectionTitleTextStyle}" />
                          <TextBlock Text="{x:Static props:Strings.AppearanceDescription}"
                                     Style="{StaticResource BodyTextStyle}"
                                     Margin="0,6,0,16" />

                          <TextBlock Text="{x:Static props:Strings.ThemePackLabel}" Style="{StaticResource LabelTextStyle}" />
                          <Grid Margin="0,6,0,10">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ThemeSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStylePremium}"
                                     Height="42"
