                      <DataTrigger Binding="{Binding HasWarningHealthIssues}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                        <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding HasCriticalHealthIssues}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                        <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <Path Width="30"
                      Height="30"
                      Stretch="Uniform"
                      Data="M 3 15 L 12 24 L 27 6"
                      StrokeThickness="3"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
