                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Path Width="23"
                      Height="23"
                      Stretch="Uniform"
                      Data="M 14 3 L 17 6 L 12 11 L 9 8 Z M 11 10 L 5 16 A 2 2 0 0 0 8 19 L 14 13"
                      Stroke="{DynamicResource MutedTextBrush}"
                      StrokeThickness="1.8"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                  <TextBlock Text="{Binding ShellRepairTitle}"
                             Foreground="{DynamicResource TextBrush}"
                             FontWeight="SemiBold"
                             TextWrapping="NoWrap" />
                  <TextBlock Text="{Binding ShellRepairDetail}"
                             Style="{StaticResource CaptionTextStyle}"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </Grid>
            </Button>
            <Button Height="58"
                    Padding="12,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    AutomationProperties.Name="{Binding ShellClearCacheTitle}"
                    AutomationProperties.HelpText="{Binding ShellClearCacheDetail}"
                    Command="{Binding ClearAssetCacheCommand}">
              <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Path Width="22"
                      Height="22"
                      Stretch="Uniform"
                      Data="M 8 3 H 16 M 10 3 L 10.5 1.5 H 13.5 L 14 3 M 5 6 H 19 M 7 6 L 8 21 H 16 L 17 6 M 10 9 V 18 M 14 9 V 18"
                      Stroke="{DynamicResource MutedTextBrush}"
                      StrokeThickness="1.8"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                  <TextBlock Text="{Binding ShellClearCacheTitle}"
                             Foreground="{DynamicResource TextBrush}"
                             FontWeight="SemiBold"
                             TextWrapping="NoWrap" />
                  <TextBlock Text="{Binding ShellClearCacheDetail}"
                             Style="{StaticResource CaptionTextStyle}"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </Grid>
            </Button>

            <StackPanel Visibility="{Binding HasAnyHealthIssues, Converter={StaticResource BoolToVisibilityConverter}}">
              <Border Height="1"
                      Background="{DynamicResource StrokeSoftBrush}"
                      Margin="0,20,0,18" />
              <TextBlock Text="{Binding HealthIssueSummary}"
                         Style="{StaticResource LabelTextStyle}"
                         Foreground="{DynamicResource WarningBrush}"
                         Margin="0,0,0,10" />
              <ItemsControl ItemsSource="{Binding CriticalHealthIssues}"
                            ItemTemplate="{StaticResource HealthIssueTemplate}" />
              <ItemsControl ItemsSource="{Binding WarningHealthIssues}"
                            ItemTemplate="{StaticResource HealthIssueTemplate}" />
            </StackPanel>

            <Border Height="1"
                    Background="{DynamicResource StrokeSoftBrush}"
                    Margin="0,22,0,20" />

            <TextBlock Text="{Binding ShellTrustRiskTitle}"
                       Style="{StaticResource SectionTitleTextStyle}"
                       FontSize="18"
                       Margin="0,0,0,14" />
            <Grid Margin="0,0,0,14">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Path Width="28"
                    Height="28"
                    Stretch="Uniform"
                    Data="M 14 2 L 25 7 V 14 C 25 21 20 25 14 28 C 8 25 3 21 3 14 V 7 Z M 9 15 L 13 19 L 20 10"
                    Stroke="{DynamicResource AccentBrush}"
                    StrokeThickness="2"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round" />
              <StackPanel Grid.Column="1" Margin="14,0,0,0">
                <TextBlock Text="{Binding ShellTrustedSourcesTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ShellTrustedSourcesDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,3,0,0" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,0,0,14">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Path Width="28"
                    Height="28"
                    Stretch="Uniform"
                    Data="M 14 2 L 25 7 V 14 C 25 21 20 25 14 28 C 8 25 3 21 3 14 V 7 Z M 14 8 V 16 M 14 20 V 21"
                    Stroke="{DynamicResource WarningBrush}"
                    StrokeThickness="2"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round" />
              <StackPanel Grid.Column="1" Margin="14,0,0,0">
                <TextBlock Text="{Binding ShellSpotifyModificationTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ShellSpotifyModificationDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,3,0,0" />
              </StackPanel>
            </Grid>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Path Width="28"
                    Height="28"
                    Stretch="Uniform"
                    Data="M 4 7 L 14 3 L 24 7 V 15 C 24 21 19 25 14 27 C 9 25 4 21 4 15 Z M 10 15 L 13 18 L 19 11"
                    Stroke="{DynamicResource InfoBrush}"
                    StrokeThickness="2"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round" />
              <StackPanel Grid.Column="1" Margin="14,0,0,0">
                <TextBlock Text="{Binding ShellBackupCreatedTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ShellBackupCreatedDetail}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,3,0,0" />
              </StackPanel>
            </Grid>

            <Border Height="1"
                    Background="{DynamicResource StrokeSoftBrush}"
                    Margin="0,22,0,16" />
            <TextBlock Text="{Binding ShellServiceStatusText}"
                       Style="{StaticResource CaptionTextStyle}"
                       Foreground="{DynamicResource AccentBrush}" />
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- ═══ Activity overlay ═══ -->
    <Border Height="48"
            VerticalAlignment="Top"
            Background="{DynamicResource CanvasBrush}"
            BorderBrush="{DynamicResource StrokeSoftBrush}"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
      <Grid>
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Margin="0,0,16,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <Button Height="32"
                  MinWidth="92"
                  Padding="10,0"
                  Margin="0,0,8,0"
                  Style="{StaticResource GhostButtonStyle}"
                  AutomationProperties.Name="{services:Loc Ui_OpenSpicetifyThemeCatalog}"
                  Command="{Binding OpenThemeCatalogCommand}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Path Width="15"
                    Height="15"
                    Stretch="Uniform"
                    Data="M 8 1 A 7 7 0 1 0 8 15 H 9.5 A 1.5 1.5 0 0 0 11 13.5 A 1.5 1.5 0 0 1 12.5 12 H 13 A 2 2 0 0 0 15 10 C 15 5 12 1 8 1 Z M 5 6 A 1 1 0 1 0 5 4 A 1 1 0 1 0 5 6 M 8 4 A 1 1 0 1 0 8 2 A 1 1 0 1 0 8 4 M 11 6 A 1 1 0 1 0 11 4 A 1 1 0 1 0 11 6"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    StrokeThickness="1.4"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round" />
              <TextBlock Text="{Binding ShellTopThemeLabel}"
                         Margin="8,0,0,0"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <ComboBox ItemsSource="{Binding LocalizationOptions}"
                    SelectedItem="{Binding SelectedLocalizationOption, Mode=TwoWay}"
                    Width="128"
                    Height="32"
                    Margin="0,0,8,0"
                    Style="{StaticResource ComboBoxStylePremium}"
                    AutomationProperties.Name="{services:Loc LanguageLabel}"
                    AutomationProperties.HelpText="{services:Loc LanguageHelpText}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayName}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <Button Height="32"
                  MinWidth="104"
                  Padding="10,0"
                  Margin="0,0,22,0"
                  Style="{StaticResource GhostButtonStyle}"
                  AutomationProperties.Name="{services:Loc Ui_CustomSettings}"
                  Command="{Binding ShowCustomWorkspaceCommand}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Path Width="15"
                    Height="15"
                    Stretch="Uniform"
                    Data="M 8 1 V 3 M 8 13 V 15 M 3 8 H 1 M 15 8 H 13 M 12.95 3.05 L 11.54 4.46 M 4.46 11.54 L 3.05 12.95 M 12.95 12.95 L 11.54 11.54 M 4.46 4.46 L 3.05 3.05 M 8 5 A 3 3 0 1 0 8 11 A 3 3 0 1 0 8 5"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    StrokeThickness="1.5"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round" />
              <TextBlock Text="{Binding ShellTopSettingsLabel}"
                         Margin="8,0,0,0"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Button Width="38"
                  Height="32"
                  Margin="0,0,2,0"
                  Style="{StaticResource GhostButtonStyle}"
                  Click="MinimizeWindow_OnClick"
                  AutomationProperties.Name="{services:Loc Ui_WindowMinimize}">
            <Path Width="12"
                  Height="1.5"
                  Stretch="Fill"
                  Data="M 0 0 H 12"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeThickness="1.5"
                  StrokeStartLineCap="Round" />
          </Button>
          <Button Width="38"
                  Height="32"
                  Margin="0,0,2,0"
                  Style="{StaticResource GhostButtonStyle}"
                  Click="MaximizeWindow_OnClick"
                  AutomationProperties.Name="{services:Loc Ui_WindowMaximize}">
            <Path Width="12"
                  Height="12"
                  Stretch="Uniform"
                  Data="M 2 2 H 10 V 10 H 2 Z"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeThickness="1.5"
                  StrokeLineJoin="Round" />
          </Button>
          <Button Width="38"
                  Height="32"
                  Style="{StaticResource GhostButtonStyle}"
                  Click="CloseWindow_OnClick"
                  AutomationProperties.Name="{services:Loc Ui_WindowClose}">
            <Path Width="11"
                  Height="11"
                  Stretch="Uniform"
                  Data="M 1 1 L 10 10 M 10 1 L 1 10"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeThickness="1.5"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Height="38"
            VerticalAlignment="Bottom"
            Background="{DynamicResource CanvasBrush}"
            BorderBrush="{DynamicResource StrokeSoftBrush}"
            BorderThickness="0,1,0,0">
      <Grid Margin="26,0,28,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="48" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="10"
                   Height="10"
                   Fill="{DynamicResource AccentBrush}"
                   Margin="0,0,10,0" />
          <TextBlock Text="{Binding ShellReadyText}"
                     Style="{StaticResource CaptionTextStyle}"
                     Foreground="{DynamicResource TextBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Ellipse Width="9"
                   Height="9"
                   Stroke="{DynamicResource MutedTextBrush}"
                   StrokeThickness="1.5"
                   Margin="0,0,8,0" />
          <TextBlock Text="{Binding ShellNoActiveTasksText}"
                     Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Ellipse Width="10"
                   Height="10"
                   Fill="{DynamicResource AccentBrush}"
                   Margin="0,0,10,0" />
          <TextBlock Text="{Binding ShellServiceStatusText}"
                     Style="{StaticResource CaptionTextStyle}"
                     Foreground="{DynamicResource MutedTextBrush}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Visibility="{Binding IsActivityVisible, Converter={StaticResource BoolToVisibilityConverter}}"
          KeyboardNavigation.TabNavigation="Cycle">
      <!-- Scrim -->
      <Border x:Name="ActivityScrim"
              Background="{DynamicResource OverlayBrush}">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsActivityVisible}" Value="True">
                <DataTrigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       From="0" To="1" Duration="{StaticResource MotionMedDuration}">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.EnterActions>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>
      <Grid Margin="64">
        <Border x:Name="ActivityDialogRoot"
                Width="900"
                MaxHeight="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="32"
                Focusable="True"
                AutomationProperties.AutomationId="ActivityDialogRoot"
                AutomationProperties.Name="{x:Static props:Strings.ActivityDialogName}"
                AutomationProperties.HelpText="{x:Static props:Strings.ActivityDialogHint}"
                Style="{StaticResource ActivityCardStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{Binding ActivityBadgeText}"
                           AutomationProperties.Name="{services:Loc Ui_RunState}">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding ActivityTitle}" Style="{StaticResource SectionTitleTextStyle}" FontSize="24" />
                <controls:LiveRegionContentControl Content="{Binding ActivityStatus}"
                                                   AutomationProperties.AutomationId="RunStatus"
                                                   AutomationProperties.Name="{services:Loc RunStatus}"
                                                   Margin="0,6,0,0">
                  <controls:LiveRegionContentControl.ContentTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" Style="{StaticResource BodyTextStyle}" />
                    </DataTemplate>
                  </controls:LiveRegionContentControl.ContentTemplate>
                </controls:LiveRegionContentControl>
              </StackPanel>
              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="20,0,0,0">
                <TextBlock Text="{x:Static props:Strings.ElapsedLabel}"
                           Style="{StaticResource LabelTextStyle}"
                           TextAlignment="Right" />
                <TextBlock Text="{Binding RunElapsedText}"
                           Foreground="{DynamicResource TextBrush}"
                           FontFamily="{StaticResource MonoFont}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,6,0,0"
                           TextAlignment="Right" />
              </StackPanel>
            </Grid>

            <!-- Progress -->
            <Border Grid.Row="1" Style="{StaticResource SubtleCardStyle}" Margin="0,20,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar Height="8"
                             Maximum="100"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             IsIndeterminate="{Binding IsBusyIndeterminate, Mode=OneWay}"
                             Style="{StaticResource ProgressBarStylePremium}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name="{x:Static props:Strings.ProgressBarName}" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                  <TextBlock Text="{Binding ProgressLabel}"
                             VerticalAlignment="Center"
                             FontFamily="{StaticResource MonoFont}"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextBrush}"
                             MinWidth="72" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Current step -->
            <Border Grid.Row="2"
                    Margin="0,14,0,0">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
                  <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                  <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                      <Setter Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                      <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                      <Setter Property="BorderBrush" Value="{DynamicResource WarningRingBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="4"
                        Height="18"
                        CornerRadius="2"
                        Margin="0,2,12,0"
                        VerticalAlignment="Top">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="{DynamicResource StrokeBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                </Border>
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding ActivityDetailLabel}">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsActivityError}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsActivityCanceled}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                          </DataTrigger>
                          <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                              <Condition Binding="{Binding IsRunning}" Value="False" />
                              <Condition Binding="{Binding IsActivityError}" Value="False" />
                              <Condition Binding="{Binding IsActivityCanceled}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                          </MultiDataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <TextBlock Text="{Binding ActivityStep}"
                             Margin="0,4,0,0"
                             Foreground="{DynamicResource TextBrush}"
                             FontWeight="SemiBold"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Log -->
            <Grid Grid.Row="3" Margin="0,20,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <Border Grid.Row="0"
                      Margin="0,0,0,14"
                      Background="{DynamicResource Surface1Brush}"
                      BorderBrush="{DynamicResource StrokeSoftBrush}"
                      BorderThickness="1"
                      CornerRadius="12"
                      Padding="16"
                      AutomationProperties.Name="{x:Static props:Strings.UndoPaneTitle}"
                      Visibility="{Binding HasUndoActionItems, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border Grid.Column="0"
                          Width="4"
                          CornerRadius="2"
                          Background="{DynamicResource AccentBrush}" />
                  <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="{x:Static props:Strings.UndoPaneTitle}"
                               Style="{StaticResource LabelTextStyle}"
                               Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="{x:Static props:Strings.UndoPaneDescription}"
                               Style="{StaticResource CaptionTextStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,4,0,10"
                               TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding UndoActionItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,3">
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{Binding Summary}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <Border Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource MicroBadgeStyle}"
                                    Margin="12,0,0,0">
                              <TextBlock Text="{Binding Action}"
                                         Style="{StaticResource MicroBadgeTextStyle}" />
                            </Border>
                            <Grid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,4,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Text="{x:Static props:Strings.UndoPaneUndoLabel}"
                                         Style="{StaticResource CaptionTextStyle}"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         FontWeight="SemiBold"
                                         Margin="0,0,6,0" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding RollbackHint}"
                                         Style="{StaticResource CaptionTextStyle}"
                                         Foreground="{DynamicResource SubtleTextBrush}"
                                         TextWrapping="Wrap" />
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Grid>
              </Border>

              <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="{x:Static props:Strings.RunLogLabel}"
                             Style="{StaticResource LabelTextStyle}"
                             VerticalAlignment="Center" />
                  <TextBlock Text="{x:Static props:Strings.RunLogDescription}"
                             Style="{StaticResource CaptionTextStyle}"
                             Margin="0,6,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding LogLineCountText}"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
              </Grid>
              <Border Grid.Row="2"
                      MinHeight="220"
                      Background="{DynamicResource TerminalBgBrush}"
                      BorderBrush="{DynamicResource StrokeBrush}"
                      BorderThickness="1"
                      CornerRadius="12">
                <Grid>
                  <!-- Empty state -->
                  <StackPanel HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              MaxWidth="420">
                    <StackPanel.Style>
                      <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding LogEntries.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{x:Static props:Strings.LogEmptyStateTitle}"
                               Style="{StaticResource EmptyStateTitleTextStyle}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Static props:Strings.LogEmptyStateHint}"
                               Style="{StaticResource EmptyStateBodyTextStyle}"
                               TextAlignment="Center"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center" />
                  </StackPanel>

                  <ListBox x:Name="LogListBox"
                           ItemsSource="{Binding LogEntries}"
                           Background="Transparent"
                           BorderThickness="0"
                           Padding="14,12"
                           ScrollViewer.VerticalScrollBarVisibility="Auto"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                           ScrollViewer.CanContentScroll="True"
                           VirtualizingPanel.IsVirtualizing="True"
                           VirtualizingPanel.VirtualizationMode="Recycling"
                           VirtualizingPanel.ScrollUnit="Pixel"
                           VirtualizingPanel.CacheLength="2"
                           VirtualizingPanel.CacheLengthUnit="Page"
                           AutomationProperties.Name="{services:Loc RunLogLabel}">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                      <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                          <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                              <ContentPresenter />
                            </ControlTemplate>
                          </Setter.Value>
                        </Setter>
                      </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,1">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TimestampDisplay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Margin="0,0,12,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Level}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                       MinWidth="58"
                                       Margin="0,0,12,0" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Message}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource TerminalFgBrush}"
                                       TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
            </Grid>

            <Grid Grid.Row="4" Margin="0,18,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel Margin="0,0,20,0">
                <TextBlock Text="{Binding ActivitySummaryTitle}"
                           Style="{StaticResource LabelTextStyle}" />
                <TextBlock Text="{Binding ActivityAssistiveText}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           MaxWidth="430" />
                <TextBlock Text="{Binding ActivityLogPathText}"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           Margin="0,8,0,0"
                           MaxWidth="430"
                           TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          HorizontalAlignment="Right">
                <Button Content="{x:Static props:Strings.ButtonCopyLog}"
                        x:Name="ActivityCopyLogButton"
                        MinWidth="120"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.AutomationId="ActivityCopyLogButton"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonCopyLogName}"
                        AutomationProperties.HelpText="{x:Static props:Strings.ButtonCopyLogHint}"
                        Command="{Binding CopyLogCommand}" />
                <Button Content="{x:Static props:Strings.ButtonExportFailureBundle}"
                        x:Name="ActivityExportFailureBundleButton"
                        MinWidth="132"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Visibility="{Binding CanExportFailureBundle, Converter={StaticResource BoolToVisibilityConverter}}"
                        AutomationProperties.AutomationId="ActivityExportFailureBundleButton"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonExportFailureBundleName}"
                        AutomationProperties.HelpText="{x:Static props:Strings.ButtonExportFailureBundleHint}"
                        Command="{Binding ExportFailureBundleCommand}" />
                <Button Content="{x:Static props:Strings.ButtonOpenFolder}"
                        x:Name="ActivityOpenLibreSpotFolderButton"
                        MinWidth="132"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.AutomationId="ActivityOpenLibreSpotFolderButton"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonOpenLibreSpotFolder}"
                        AutomationProperties.HelpText="{x:Static props:Strings.ButtonOpenLibreSpotFolderActivityHint}"
                        Command="{Binding OpenLibreSpotFolderCommand}" />
                <Button Content="{x:Static props:Strings.ButtonCancelRun}"
                        x:Name="ActivityCancelRunButton"
                        MinWidth="140"
                        Height="42"
                        Padding="18,0"
                        Margin="0,0,10,0"
                        Style="{StaticResource DestructiveButtonStyle}"
                        AutomationProperties.AutomationId="ActivityCancelRunButton"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonCancelRunName}"
                        AutomationProperties.HelpText="{x:Static props:Strings.ButtonCancelRunHint}"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding CancelRunCommand}" />
                <Button Content="{x:Static props:Strings.ButtonClose}"
                        x:Name="ActivityCloseButton"
                        MinWidth="140"
                        Height="42"
                        Padding="18,0"
                        AutomationProperties.AutomationId="ActivityCloseButton"
                        AutomationProperties.Name="{services:Loc Ui_CloseActivityPanel}"
                        AutomationProperties.HelpText="{services:Loc Ui_DismissesTheActivityPanelAfterTheRunIs}"
                        Command="{Binding DismissActivityCommand}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- ═══ Prompt overlay ═══ -->
    <Grid Visibility="{Binding IsPromptVisible, Converter={StaticResource BoolToVisibilityConverter}}"
          KeyboardNavigation.TabNavigation="Cycle">
      <Border Background="{DynamicResource OverlayBrush}">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsPromptVisible}" Value="True">
                <DataTrigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       From="0" To="1" Duration="{StaticResource MotionMedDuration}">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.EnterActions>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>
      <Grid Margin="64">
        <Border x:Name="PromptDialogRoot"
                Width="540"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="30"
                AutomationProperties.AutomationId="PromptDialogRoot"
                AutomationProperties.Name="{services:Loc Ui_DecisionPrompt}"
                AutomationProperties.HelpText="{services:Loc Ui_ConfirmsAnImportantLibreSpotActionBeforeItRuns}"
                Style="{StaticResource PromptCardStyle}">
          <StackPanel>
            <TextBlock FontWeight="SemiBold"
                       FontSize="11">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                  <Setter Property="Text" Value="{x:Static props:Strings.PromptActionConfirm}" />
                  <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsPromptDestructive}" Value="True">
                      <Setter Property="Text" Value="{x:Static props:Strings.PromptActionReset}" />
                      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="{Binding PromptTitle}" Style="{StaticResource SectionTitleTextStyle}" FontSize="22" />
            <TextBlock Text="{Binding PromptBody}" Style="{StaticResource BodyTextStyle}" Margin="0,12,0,0" />
            <Border Height="1"
                    Background="{DynamicResource StrokeSoftBrush}"
                    Margin="0,18,0,16" />
            <TextBlock Text="{Binding PromptSummaryTitle}">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsPromptDestructive}" Value="True">
                      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding PromptSummaryBody}"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
              <Button Content="{Binding PromptCancelText}"
                      x:Name="PromptCancelButton"
                      MinWidth="160"
                      Height="42"
                      Padding="18,0"
                      Margin="0,0,10,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      AutomationProperties.AutomationId="PromptCancelButton"
                      AutomationProperties.Name="{Binding PromptCancelText}"
                      IsCancel="True"
                      Command="{Binding CancelPromptCommand}" />
              <Button MinWidth="200"
                      x:Name="PromptConfirmButton"
                      Height="42"
                      Padding="18,0"
                      Content="{Binding PromptConfirmText}"
                      AutomationProperties.AutomationId="PromptConfirmButton"
                      AutomationProperties.Name="{Binding PromptConfirmText}"
                      IsDefault="{Binding IsPromptConfirmDefault}"
                      Command="{Binding ConfirmPromptCommand}">
                <Button.Style>
                  <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsPromptDestructive}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource DangerFillBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextOnDangerBrush}" />
                        <Setter Property="Tag" Value="{DynamicResource DangerHoverTintBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Button.Style>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <ui:SnackbarPresenter x:Name="CompletionSnackbarPresenter"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,28,28"
                          Panel.ZIndex="100"
                          AutomationProperties.Name="{services:Loc Ui_CompletionNotifications}" />
  </Grid>
</Window>
