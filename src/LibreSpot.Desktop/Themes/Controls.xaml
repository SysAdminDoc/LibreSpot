<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
                    xmlns:props="clr-namespace:LibreSpot.Desktop.Properties">
  <!--
    LibreSpot Desktop control styles.
    Conventions:
      • Radius rhythm:    6 inline, 8 badges, 10 controls, 12 cards.
      • Focus visual:     overlay ring that never changes container thickness,
                          so focus never shifts layout.
      • State transitions: short (~150ms) ease-out on color/opacity for hover,
                          press, and selection. No bouncy overshoot.
      • Disabled:         40-45% opacity + Cursor=Arrow so intent is clear.
  -->

  <!-- ═══ Window ═══ -->
  <Style x:Key="WindowChromeStyle" TargetType="Window">
    <Setter Property="Background" Value="{DynamicResource CanvasBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <!-- ═══ Typography ═══ -->
  <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
  </Style>

  <Style x:Key="HeadlineTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource HeadingFont}" />
    <Setter Property="FontSize" Value="30" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="38" />
  </Style>

  <Style x:Key="RailTitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource HeadingFont}" />
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource HeadingFont}" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="BodyTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="20" />
  </Style>

  <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="18" />
  </Style>

  <Style x:Key="LabelTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <!-- Micro-label (eyebrow rail/section). Slightly lifted font for rhythm. -->
  <Style x:Key="SectionEyebrowTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="Margin" Value="0,0,0,10" />
  </Style>

  <Style x:Key="MicroBadgeStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusBadge}" />
    <Setter Property="Padding" Value="9,3" />
    <Setter Property="MinHeight" Value="22" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style x:Key="MicroBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="TextWrapping" Value="NoWrap" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="EmptyStateTitleTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="FontFamily" Value="{StaticResource HeadingFont}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="EmptyStateBodyTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
    <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="18" />
  </Style>

  <!-- ═══ Cards / Surfaces ═══ -->
  <Style x:Key="SurfaceCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}" />
    <Setter Property="Padding" Value="22" />
    <Setter Property="Effect" Value="{DynamicResource CardShadow}" />
  </Style>

  <Style x:Key="SubtleCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
    <Setter Property="Padding" Value="18" />
  </Style>

  <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource SubtleCardStyle}">
    <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
    <Setter Property="Padding" Value="20" />
  </Style>

  <Style x:Key="SectionFrameStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}" />
    <Setter Property="Padding" Value="24" />
  </Style>

  <!--
    Button templates use an overlay-tint border for smooth hover transitions
    instead of animating (Background).(SolidColorBrush.Color). Palette brushes
    are frozen when they're resolved from a shared ResourceDictionary, and
    WPF throws on ColorAnimation against a frozen Freezable. Fading an Opacity
    from 0→1 on a tint overlay avoids that problem entirely and keeps the
    transition compositional (no re-evaluation per frame).
  -->

  <!-- ═══ Primary button ═══ -->
  <Style x:Key="PrimaryButtonStyle" TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Tag" Value="{DynamicResource AccentHoverBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
            </Grid.RenderTransform>
            <Border x:Name="FocusRing"
                    Margin="-3"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource AccentRingBrush}"
                    BorderThickness="2"
                    Opacity="0" />
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="12" />
            <!-- Hover tint overlay; opacity fades 0→1 -->
            <Border x:Name="HoverTint"
                    Background="{TemplateBinding Tag}"
                    CornerRadius="12"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <!-- Pressed overlay (subtle darkening) -->
            <Border x:Name="PressTint"
                    Background="{DynamicResource PressTintBrush}"
                    CornerRadius="12"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}"
                              TextElement.Foreground="{TemplateBinding Foreground}"
                              RecognizesAccessKey="True" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="{StaticResource MotionMedDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="{StaticResource MotionSlowDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="{StaticResource MotionFastDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="0.985" Duration="{StaticResource MotionFastDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="0.985" Duration="{StaticResource MotionFastDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="{StaticResource MotionMedDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1.0" Duration="{StaticResource MotionMedDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1.0" Duration="{StaticResource MotionMedDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.4" />
              <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Secondary: tonal surface button -->
  <Style x:Key="SecondaryButtonStyle" TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Tag" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
            </Grid.RenderTransform>
            <Border x:Name="FocusRing"
                    Margin="-3"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource AccentRingBrush}"
                    BorderThickness="2"
                    Opacity="0" />
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="12" />
            <Border x:Name="HoverTint"
                    Background="{TemplateBinding Tag}"
                    CornerRadius="12"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <Border x:Name="PressTint"
                    Background="{DynamicResource PressTintBrush}"
                    CornerRadius="12"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}"
                              TextElement.Foreground="{TemplateBinding Foreground}"
                              RecognizesAccessKey="True" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="{StaticResource MotionMedDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="{StaticResource MotionSlowDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="{StaticResource MotionFastDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="0.985" Duration="{StaticResource MotionFastDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="0.985" Duration="{StaticResource MotionFastDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="{StaticResource MotionMedDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1.0" Duration="{StaticResource MotionMedDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1.0" Duration="{StaticResource MotionMedDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.4" />
              <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Ghost: low-emphasis transparent-on-rail -->
  <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="Background" Value="{DynamicResource GhostButtonBgBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource GhostButtonBorderBrush}" />
    <Setter Property="Tag" Value="{DynamicResource GhostHoverTintBrush}" />
  </Style>

  <Style x:Key="ShellNavButtonStyle" TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="MinHeight" Value="44" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Tag" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
            </Grid.RenderTransform>
            <Border x:Name="FocusRing"
                    Margin="-2"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource AccentRingBrush}"
                    BorderThickness="2"
                    Opacity="0" />
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8" />
            <Border x:Name="HoverTint"
                    Background="{TemplateBinding Tag}"
                    CornerRadius="8"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <Border x:Name="AccentRail"
                    Width="4"
                    HorizontalAlignment="Left"
                    CornerRadius="2"
                    Background="{DynamicResource AccentBrush}"
                    Opacity="0" />
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"
                              RecognizesAccessKey="True" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="HoverTint" Property="Opacity" Value="1" />
              <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45" />
              <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Destructive: DangerFill/TextOnDanger pair keeps the label readable on the fill
       (WCAG AA in the dark palette) and flattens to a normal control surface in HC,
       where the DangerBrush border + label carry the destructive meaning. -->
  <Style x:Key="DestructiveButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
    <Setter Property="Foreground" Value="{DynamicResource TextOnDangerBrush}" />
    <Setter Property="Background" Value="{DynamicResource DangerFillBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    <Setter Property="Tag" Value="{DynamicResource DangerHoverTintBrush}" />
  </Style>

  <!-- ═══ Tabs ═══ -->
  <Style x:Key="WorkspaceTabControlStyle" TargetType="TabControl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabControl">
          <Grid KeyboardNavigation.TabNavigation="Local">
            <Grid.RowDefinitions>
              <RowDefinition Height="0" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TabPanel Grid.Row="0"
                      IsItemsHost="True"
                      Visibility="Collapsed" />
            <ContentPresenter x:Name="PART_SelectedContentHost"
                              Grid.Row="1"
                              ContentSource="SelectedContent"
                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="WorkspaceTabItemStyle" TargetType="TabItem">
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Grid>
            <!-- Focus ring overlay (never changes layout) -->
            <Border x:Name="FocusRing"
                    Margin="0"
                    CornerRadius="10"
                    BorderBrush="{DynamicResource AccentRingBrush}"
                    BorderThickness="2"
                    Opacity="0" />
            <Border x:Name="Root"
                    Background="Transparent"
                    CornerRadius="10"
                    Padding="12,6"
                    Margin="2,0">
              <ContentPresenter x:Name="Content"
                                ContentSource="Header"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
            </Border>
            <Border x:Name="HoverTint"
                    Margin="2,0"
                    Background="{DynamicResource SurfaceSheenBrush}"
                    CornerRadius="10"
                    Opacity="0"
                    IsHitTestVisible="False" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentGradientBrush}" />
              <Setter TargetName="Root" Property="Effect" Value="{DynamicResource TabSelectedGlow}" />
              <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
              <Setter TargetName="HoverTint" Property="Opacity" Value="0" />
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="IsSelected" Value="False" />
              </MultiTrigger.Conditions>
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource Surface3Brush}" />
              <Setter TargetName="HoverTint" Property="Opacity" Value="1" />
              <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            </MultiTrigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
              <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ Checkbox card (used for every toggle) ═══ -->
  <Style x:Key="SettingCheckBoxStyle" TargetType="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
            </Grid.RenderTransform>
            <Border x:Name="FocusRing"
                    Margin="-3"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource AccentRingBrush}"
                    BorderThickness="2"
                    Opacity="0" />
            <Border x:Name="Root"
                    Background="{DynamicResource Surface1Brush}"
                    BorderBrush="{DynamicResource StrokeSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="0" />
            <Border x:Name="HoverTint"
                    Background="{DynamicResource SurfaceSheenBrush}"
                    CornerRadius="10"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <Border x:Name="PressTint"
                    Background="{DynamicResource PressTintLightBrush}"
                    CornerRadius="10"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <Grid Margin="16,13">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid VerticalAlignment="Top" Margin="0,2,0,0">
                <Border x:Name="Box"
                        Width="18"
                        Height="18"
                        CornerRadius="5"
                        Background="{DynamicResource Surface3Brush}"
                        BorderBrush="{DynamicResource StrokeStrongBrush}"
                        BorderThickness="1.2" />
                <Path x:Name="Mark"
                      Width="11"
                      Height="10"
                      Stretch="Uniform"
                      Data="M 1 5 L 4.5 8.5 L 10 2"
                      Stroke="{DynamicResource TextOnAccentBrush}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Opacity="0" />
              </Grid>
              <ContentPresenter Grid.Column="2"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
            </Grid>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
              <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentBrush}" />
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Mark"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="{StaticResource MotionFastDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Mark"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="{StaticResource MotionFastDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1"
                                     Duration="{StaticResource MotionMedDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1.01"
                                     Duration="{StaticResource MotionMedDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1.01"
                                     Duration="{StaticResource MotionMedDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0"
                                     Duration="{StaticResource MotionSlowDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1"
                                     Duration="{StaticResource MotionSlowDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1"
                                     Duration="{StaticResource MotionSlowDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="IsChecked" Value="True" />
              </MultiTrigger.Conditions>
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
            </MultiTrigger>
            <Trigger Property="IsPressed" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1"
                                     Duration="{StaticResource MotionFastDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="0.992"
                                     Duration="{StaticResource MotionFastDuration}" />
                    <DoubleAnimation Storyboard.TargetName="RootScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="0.992"
                                     Duration="{StaticResource MotionFastDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressTint"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0"
                                     Duration="{StaticResource MotionMedDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45" />
              <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ ComboBox item ═══ -->
  <Style x:Key="ComboBoxItemPremium" TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <!-- Constant border thickness: the keyboard focus ring swaps brush only,
               so focus never shifts layout. -->
          <Border x:Name="Root"
                  Background="Transparent"
                  BorderBrush="Transparent"
                  BorderThickness="1.5"
                  CornerRadius="8"
                  Padding="{TemplateBinding Padding}"
                  Margin="2,1">
            <ContentPresenter VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource Surface3Brush}" />
            </Trigger>
            <!-- Keyboard highlight uses the accent selection pairing (Highlight/HighlightText
                 in HC) — AccentSoftBrush is indistinguishable from the popup surface. -->
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentBrush}" />
              <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentBrush}" />
              <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ ComboBox ═══ -->
  <Style x:Key="ComboBoxStylePremium" TargetType="ComboBox">
    <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14,9" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemPremium}" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <Border x:Name="FocusRing"
                    Margin="-2"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource AccentRingBrush}"
                    BorderThickness="2"
                    Opacity="0" />
            <ToggleButton Name="ToggleButton"
                          Focusable="False"
                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                          ClickMode="Press">
              <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                  <Border x:Name="Root"
                          Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                          BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                          BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                          CornerRadius="12"
                          Padding="14,9">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ContentPresenter VerticalAlignment="Center" />
                      <Path x:Name="Chevron"
                            Grid.Column="1"
                            Width="10"
                            Height="6"
                            Margin="12,0,0,0"
                            Stretch="Uniform"
                            Data="M 0 0 L 5 5 L 10 0"
                            Stroke="{DynamicResource MutedTextBrush}"
                            StrokeThickness="1.7"
                            StrokeStartLineCap="Round"
                            StrokeEndLineCap="Round"
                            RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                          <RotateTransform x:Name="ChevronRotate" Angle="0" />
                        </Path.RenderTransform>
                      </Path>
                    </Grid>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}" />
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                      <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                      <Trigger.EnterActions>
                        <BeginStoryboard>
                          <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ChevronRotate"
                                             Storyboard.TargetProperty="Angle"
                                             To="180" Duration="{StaticResource MotionMedDuration}" />
                          </Storyboard>
                        </BeginStoryboard>
                      </Trigger.EnterActions>
                      <Trigger.ExitActions>
                        <BeginStoryboard>
                          <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ChevronRotate"
                                             Storyboard.TargetProperty="Angle"
                                             To="0" Duration="{StaticResource MotionMedDuration}" />
                          </Storyboard>
                        </BeginStoryboard>
                      </Trigger.ExitActions>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </ToggleButton.Template>
            </ToggleButton>
            <ContentPresenter x:Name="Content"
                              Margin="14,0,40,0"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              IsHitTestVisible="False"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                              TextElement.Foreground="{TemplateBinding Foreground}" />
            <Popup Name="Popup"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   Placement="Bottom"
                   AllowsTransparency="True"
                   PopupAnimation="Slide">
              <Border Background="{DynamicResource Surface2Brush}"
                      BorderBrush="{DynamicResource StrokeBrush}"
                      BorderThickness="1"
                      CornerRadius="12"
                      Margin="0,6,0,0"
                      MinWidth="{Binding ActualWidth, ElementName=ToggleButton}"
                      Effect="{DynamicResource CardShadow}">
                <ScrollViewer Margin="4"
                              MaxHeight="320"
                              CanContentScroll="True"
                              VerticalScrollBarVisibility="Auto">
                  <StackPanel IsItemsHost="True"
                              KeyboardNavigation.DirectionalNavigation="Contained" />
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ TextBox ═══ -->
  <Style x:Key="TextBoxStylePremium" TargetType="TextBox">
    <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource AccentRingBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14,9" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Grid>
            <Border x:Name="FocusRing"
                    Margin="-2"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource AccentRingBrush}"
                    BorderThickness="2"
                    Opacity="0" />
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="12">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}" />
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
              <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ Progress bar — determinate fill + indeterminate shimmer sweep ═══ -->
  <Style x:Key="ProgressBarStylePremium" TargetType="ProgressBar">
    <Setter Property="Height" Value="8" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Grid ClipToBounds="True">
            <Border x:Name="Track"
                    Background="{TemplateBinding Background}"
                    CornerRadius="4" />
            <Border x:Name="PART_Track"
                    Background="Transparent"
                    CornerRadius="4" />
            <Border x:Name="PART_Indicator"
                    HorizontalAlignment="Left"
                    CornerRadius="4"
                    Background="{DynamicResource AccentGradientBrush}"
                    Visibility="Visible" />
            <!-- Indeterminate shimmer: translucent sweep across the full track -->
            <Border x:Name="Shimmer"
                    CornerRadius="4"
                    Background="{DynamicResource ShimmerBrush}"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Margin="-80,0,-80,0"
                    HorizontalAlignment="Left"
                    RenderTransformOrigin="0,0.5">
              <Border.RenderTransform>
                <TranslateTransform x:Name="ShimmerTranslate" X="-400" />
              </Border.RenderTransform>
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsIndeterminate" Value="True">
              <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed" />
              <Setter TargetName="Shimmer" Property="Opacity" Value="1" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="-400" To="1400"
                                     Duration="0:0:1.6" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ Log textbox (monospace terminal) ═══ -->
  <Style x:Key="LogTextBoxStyle" TargetType="TextBox">
    <Setter Property="Background" Value="{DynamicResource TerminalBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TerminalFgBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource AccentRingBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="16" />
    <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="IsReadOnly" Value="True" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="LogRoot"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="12">
            <ScrollViewer x:Name="PART_ContentHost"
                          Margin="{TemplateBinding Padding}" />
          </Border>
          <ControlTemplate.Triggers>
            <!-- The log is read-only but still a tab stop (users focus it to
                 scroll and copy), so it needs a visible focus indicator per
                 WCAG 2.2 SC 2.4.7. -->
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="LogRoot" Property="BorderBrush" Value="{DynamicResource AccentRingBrush}" />
              <Setter TargetName="LogRoot" Property="BorderThickness" Value="2" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ Custom scrollbars ═══ -->
  <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border x:Name="Thumb"
                  Background="{DynamicResource StrokeSoftBrush}"
                  CornerRadius="4"
                  Margin="2"
                  Opacity="0.68" />
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource MutedTextBrush}" />
              <Setter TargetName="Thumb" Property="Opacity" Value="0.95" />
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
              <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource AccentBrush}" />
              <Setter TargetName="Thumb" Property="Opacity" Value="1" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ScrollBar">
    <Setter Property="Width" Value="8" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource StrokeStrongBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid Background="Transparent">
            <Track x:Name="PART_Track"
                   IsDirectionReversed="true">
              <!-- Invisible page-scroll zones must not be keyboard tab stops. -->
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="ScrollBar.PageUpCommand"
                              Opacity="0"
                              Focusable="False"
                              IsTabStop="False"
                              AutomationProperties.Name="Scroll page up" />
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="ScrollBar.PageDownCommand"
                              Opacity="0"
                              Focusable="False"
                              IsTabStop="False"
                              AutomationProperties.Name="Scroll page down" />
              </Track.IncreaseRepeatButton>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Height" Value="8" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid Background="Transparent">
                <Track x:Name="PART_Track">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Opacity="0"
                                  Focusable="False"
                                  IsTabStop="False"
                                  AutomationProperties.Name="Scroll page left" />
                  </Track.DecreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                  </Track.Thumb>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                  Opacity="0"
                                  Focusable="False"
                                  IsTabStop="False"
                                  AutomationProperties.Name="Scroll page right" />
                  </Track.IncreaseRepeatButton>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ═══ Status dot (semantic color indicator) ═══ -->
  <Style x:Key="StatusDotStyle" TargetType="Ellipse">
    <Setter Property="Width" Value="8" />
    <Setter Property="Height" Value="8" />
    <Setter Property="Fill" Value="{DynamicResource MutedTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!--
    ═══ Completion snackbar (WPF-UI Snackbar host) ═══
    WPF-UI 4.x ships no themes/generic.xaml — Snackbar templates only exist in the
    library's resource dictionaries, which we deliberately do NOT merge: their
    ControlsDictionary injects implicit styles for TextBlock/ListBox/ScrollViewer
    that fight this app's token-driven styling, and the upstream Snackbar template
    hardcodes light/dark colors that ignore the high-contrast palette swap.
    Instead this implicit style supplies a palette-token template so the completion
    snackbar renders correctly in both the dark and high-contrast palettes:
      Success → accent fill + TextOnAccent  (Highlight/HighlightText in HC)
      Caution → WarningFill + TextOnWarning (normal HC surface, Warning border)
      Danger  → DangerFill + TextOnDanger   (normal HC surface, Danger border)
    Show/hide is Setter-driven (no storyboard) so it is instant under reduced
    motion and high contrast; SnackbarPresenter handles queueing and timeout.
  -->
  <Style TargetType="ui:Snackbar">
    <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="ContentForeground" Value="{DynamicResource TextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="56" />
    <Setter Property="MinWidth" Value="320" />
    <Setter Property="MaxWidth" Value="560" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ui:Snackbar">
          <Grid x:Name="Root" Opacity="0" Visibility="Collapsed">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="12"
                    Padding="16,12"
                    Effect="{DynamicResource CardShadow}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ContentPresenter x:Name="IconPresenter"
                                  Grid.Column="0"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center"
                                  Content="{TemplateBinding Icon}"
                                  TextElement.FontSize="22"
                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <ContentPresenter Content="{TemplateBinding Title}"
                                    ContentTemplate="{TemplateBinding TitleTemplate}"
                                    TextElement.FontSize="13.5"
                                    TextElement.FontWeight="SemiBold"
                                    TextElement.Foreground="{TemplateBinding Foreground}" />
                  <ContentPresenter Content="{TemplateBinding Content}"
                                    ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Margin="0,2,0,0"
                                    TextElement.FontSize="12.5"
                                    TextElement.Foreground="{TemplateBinding ContentForeground}" />
                </StackPanel>
                <Button x:Name="CloseButton"
                        Grid.Column="2"
                        Width="28"
                        Height="28"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Foreground="{TemplateBinding Foreground}"
                        Command="{Binding TemplateButtonCommand, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                        AutomationProperties.Name="{x:Static props:Strings.ButtonDismiss}">
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Grid>
                        <Border x:Name="CloseFocusRing"
                                Margin="-2"
                                CornerRadius="10"
                                BorderBrush="{DynamicResource AccentRingBrush}"
                                BorderThickness="2"
                                Opacity="0" />
                        <Border x:Name="CloseBg"
                                Background="Transparent"
                                CornerRadius="8" />
                        <Path Width="10"
                              Height="10"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Uniform"
                              Data="M 0 0 L 10 10 M 10 0 L 0 10"
                              Stroke="{TemplateBinding Foreground}"
                              StrokeThickness="1.7"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                      </Grid>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="CloseBg" Property="Background" Value="{DynamicResource PressTintLightBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                          <Setter TargetName="CloseFocusRing" Property="Opacity" Value="1" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                </Button>
              </Grid>
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Icon" Value="{x:Null}">
              <Setter TargetName="IconPresenter" Property="Margin" Value="0" />
            </Trigger>
            <Trigger Property="IsCloseButtonEnabled" Value="False">
              <Setter TargetName="CloseButton" Property="Visibility" Value="Collapsed" />
              <Setter TargetName="CloseButton" Property="Margin" Value="0" />
            </Trigger>
            <Trigger Property="IsShown" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="1" />
              <Setter TargetName="Root" Property="Visibility" Value="Visible" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="Appearance" Value="Success">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        <Setter Property="ContentForeground" Value="{DynamicResource TextOnAccentBrush}" />
      </Trigger>
      <Trigger Property="Appearance" Value="Caution">
        <Setter Property="Background" Value="{DynamicResource WarningFillBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextOnWarningBrush}" />
        <Setter Property="ContentForeground" Value="{DynamicResource TextOnWarningBrush}" />
      </Trigger>
      <Trigger Property="Appearance" Value="Danger">
        <Setter Property="Background" Value="{DynamicResource DangerFillBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextOnDangerBrush}" />
        <Setter Property="ContentForeground" Value="{DynamicResource TextOnDangerBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ═══ Overlay scrim & card entrance motion ═══ -->
  <Storyboard x:Key="OverlayEnterStoryboard">
    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                     From="0" To="1"
                     Duration="{StaticResource MotionSlowDuration}">
      <DoubleAnimation.EasingFunction>
        <CubicEase EasingMode="EaseOut" />
      </DoubleAnimation.EasingFunction>
    </DoubleAnimation>
  </Storyboard>
</ResourceDictionary>
