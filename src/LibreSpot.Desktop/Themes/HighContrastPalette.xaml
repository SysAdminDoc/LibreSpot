<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
  <!--
    High-contrast palette for the LibreSpot WPF shell.

    Every resource key from Palette.xaml is present here so StaticResource
    lookups resolve correctly when ThemeManager swaps dictionaries.  Brushes
    map to SystemColors so the shell respects whichever high-contrast theme
    the user chose (HC #1, HC #2, HC Black, HC White).

    Shadows, glows, gradients, and sheens are flattened to transparent or
    solid equivalents.  Motion durations are set to near-zero so animations
    complete instantly without being skipped (Duration.Zero can cause WPF
    animation-engine edge cases).
  -->

  <!-- ═══ Typography ═══ -->
  <FontFamily x:Key="HeadingFont">Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI</FontFamily>
  <FontFamily x:Key="BodyFont">Segoe UI Variable Text, Segoe UI</FontFamily>
  <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas</FontFamily>

  <!-- ═══ Surfaces — fallback values for Color key lookups ═══ -->
  <!-- Brush keys below use DynamicResource to real SystemColors and handle
       rendering.  These Color keys exist so StaticResource lookups from
       gradient stops or animation targets resolve without crashing.  They
       approximate HC Black defaults; actual on-screen colors come from the
       Brush definitions. -->
  <Color x:Key="CanvasColor">#000000</Color>
  <Color x:Key="CanvasShadeColor">#000000</Color>
  <Color x:Key="Surface1Color">#1A1A1A</Color>
  <Color x:Key="Surface2Color">#1A1A1A</Color>
  <Color x:Key="Surface3Color">#1A1A1A</Color>
  <Color x:Key="SurfaceRaisedColor">#1A1A1A</Color>
  <Color x:Key="RailColor">#000000</Color>
  <Color x:Key="HeroStartColor">#1A1A1A</Color>
  <Color x:Key="HeroEndColor">#000000</Color>

  <!-- ═══ Strokes ═══ -->
  <Color x:Key="StrokeColor">#666666</Color>
  <Color x:Key="StrokeSoftColor">#666666</Color>
  <Color x:Key="StrokeStrongColor">#999999</Color>

  <!-- ═══ Text ═══ -->
  <Color x:Key="TextColor">#FFFFFF</Color>
  <Color x:Key="TextMutedColor">#AAAAAA</Color>
  <Color x:Key="TextSubtleColor">#AAAAAA</Color>
  <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

  <!-- ═══ Brand / accent ═══ -->
  <Color x:Key="AccentColor">#0078D7</Color>
  <Color x:Key="AccentHoverColor">#0078D7</Color>
  <Color x:Key="AccentDeepColor">#0078D7</Color>
  <Color x:Key="AccentSoftColor">#1A1A1A</Color>
  <Color x:Key="AccentMistColor">Transparent</Color>
  <Color x:Key="AccentRingColor">#0078D7</Color>

  <!-- ═══ Semantic intent ═══ -->
  <!-- Danger maps to the HC theme's attention color (HotTrack) so error and
       success states are distinguishable; success stays on WindowText. -->
  <Color x:Key="DangerColor">#00CCFF</Color>
  <Color x:Key="DangerDeepColor">#00CCFF</Color>
  <Color x:Key="DangerSoftColor">#1A1A1A</Color>
  <!-- Fill + text-on-fill pairs: destructive/caution fills flatten to normal control
       surfaces in HC (label + border carry the meaning, not the fill). -->
  <Color x:Key="DangerFillColor">#1A1A1A</Color>
  <Color x:Key="TextOnDangerColor">#FFFFFF</Color>
  <Color x:Key="WarningFillColor">#1A1A1A</Color>
  <Color x:Key="TextOnWarningColor">#FFFFFF</Color>
  <Color x:Key="WarningColor">#00CCFF</Color>
  <Color x:Key="WarningSoftColor">#1A1A1A</Color>
  <Color x:Key="WarningRingColor">#00CCFF</Color>
  <Color x:Key="SuccessColor">#FFFFFF</Color>
  <Color x:Key="SuccessSoftColor">#1A1A1A</Color>
  <Color x:Key="InfoColor">#00CCFF</Color>

  <!-- ═══ Overlays / scrim ═══ -->
  <Color x:Key="OverlayColor">#000000</Color>
  <Color x:Key="ScrimColor">#000000</Color>
  <Color x:Key="SheenColor">Transparent</Color>

  <!-- ═══ Brushes ═══ -->
  <SolidColorBrush x:Key="CanvasBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
  <SolidColorBrush x:Key="MicaCanvasBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
  <SolidColorBrush x:Key="RailBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
  <SolidColorBrush x:Key="HeroStartBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="HeroEndBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />

  <SolidColorBrush x:Key="PanelBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="PanelStrongBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="Surface1Brush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="Surface2Brush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="Surface3Brush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="CanvasShadeBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />

  <SolidColorBrush x:Key="StrokeBrush" Color="{DynamicResource {x:Static SystemColors.ActiveBorderColorKey}}" />
  <SolidColorBrush x:Key="StrokeSoftBrush" Color="{DynamicResource {x:Static SystemColors.ActiveBorderColorKey}}" />
  <SolidColorBrush x:Key="StrokeStrongBrush" Color="{DynamicResource {x:Static SystemColors.WindowFrameColorKey}}" />

  <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}" />
  <SolidColorBrush x:Key="MutedTextBrush" Color="{DynamicResource {x:Static SystemColors.GrayTextColorKey}}" />
  <SolidColorBrush x:Key="SubtleTextBrush" Color="{DynamicResource {x:Static SystemColors.GrayTextColorKey}}" />
  <SolidColorBrush x:Key="TextOnAccentBrush" Color="{DynamicResource {x:Static SystemColors.HighlightTextColorKey}}" />

  <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
  <SolidColorBrush x:Key="AccentHoverBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
  <SolidColorBrush x:Key="AccentDeepBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
  <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="AccentMistBrush" Color="Transparent" />
  <SolidColorBrush x:Key="AccentRingBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />

  <!-- Danger text/borders map to the HC attention color (HotTrack) so error states
       are distinguishable from success text, which stays on WindowText. -->
  <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource {x:Static SystemColors.HotTrackColorKey}}" />
  <SolidColorBrush x:Key="DangerDeepBrush" Color="{DynamicResource {x:Static SystemColors.HotTrackColorKey}}" />
  <SolidColorBrush x:Key="DangerSoftBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="DangerFillBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="TextOnDangerBrush" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}" />
  <SolidColorBrush x:Key="WarningFillBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="TextOnWarningBrush" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}" />
  <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource {x:Static SystemColors.HotTrackColorKey}}" />
  <SolidColorBrush x:Key="WarningSoftBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="WarningRingBrush" Color="{DynamicResource {x:Static SystemColors.HotTrackColorKey}}" />
  <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}" />
  <SolidColorBrush x:Key="SuccessSoftBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource {x:Static SystemColors.HotTrackColorKey}}" />

  <SolidColorBrush x:Key="OverlayBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
  <SolidColorBrush x:Key="ScrimBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
  <SolidColorBrush x:Key="SheenBrush" Color="Transparent" />

  <Color x:Key="TerminalBgColor">#000000</Color>
  <Color x:Key="TerminalFgColor">#FFFFFF</Color>
  <SolidColorBrush x:Key="TerminalBgBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
  <SolidColorBrush x:Key="TerminalFgBrush" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}" />

  <!-- ═══ Radius rhythm (unchanged) ═══ -->
  <CornerRadius x:Key="RadiusSm">6</CornerRadius>
  <CornerRadius x:Key="RadiusMd">8</CornerRadius>
  <CornerRadius x:Key="RadiusLg">10</CornerRadius>
  <CornerRadius x:Key="RadiusXl">12</CornerRadius>
  <CornerRadius x:Key="RadiusBadge">8</CornerRadius>

  <!-- ═══ Spacing (unchanged) ═══ -->
  <Thickness x:Key="SpaceXs">4</Thickness>
  <Thickness x:Key="SpaceSm">8</Thickness>
  <Thickness x:Key="SpaceMd">12</Thickness>
  <Thickness x:Key="SpaceLg">16</Thickness>
  <Thickness x:Key="SpaceXl">24</Thickness>
  <Thickness x:Key="SpaceXxl">32</Thickness>

  <!-- ═══ Interactive overlays — transparent in HC (shape/border conveys state) ═══ -->
  <SolidColorBrush x:Key="GhostButtonBgBrush" Color="Transparent" />
  <SolidColorBrush x:Key="GhostButtonBorderBrush" Color="{DynamicResource {x:Static SystemColors.ActiveBorderColorKey}}" />
  <SolidColorBrush x:Key="GhostHoverTintBrush" Color="Transparent" />
  <SolidColorBrush x:Key="DangerHoverTintBrush" Color="Transparent" />
  <SolidColorBrush x:Key="PressTintBrush" Color="Transparent" />
  <SolidColorBrush x:Key="PressTintLightBrush" Color="Transparent" />

  <!-- ═══ Gradients flattened to solid equivalents ═══ -->
  <SolidColorBrush x:Key="RailGlowBrush" Color="Transparent" />
  <SolidColorBrush x:Key="SurfaceSheenBrush" Color="Transparent" />
  <SolidColorBrush x:Key="AccentGradientBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
  <SolidColorBrush x:Key="HeroPanelBrush" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
  <SolidColorBrush x:Key="HeroRingBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
  <SolidColorBrush x:Key="ShimmerBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />

  <!-- ═══ Elevation — shadows disabled (zero opacity) ═══ -->
  <DropShadowEffect x:Key="CardShadow" BlurRadius="0" ShadowDepth="0" Opacity="0" Color="Black" />
  <DropShadowEffect x:Key="OverlayShadow" BlurRadius="0" ShadowDepth="0" Opacity="0" Color="Black" />
  <DropShadowEffect x:Key="AccentGlow" BlurRadius="0" ShadowDepth="0" Opacity="0" Color="Black" />
  <DropShadowEffect x:Key="TabSelectedGlow" BlurRadius="0" ShadowDepth="0" Opacity="0" Color="Black" />

  <!-- ═══ Motion tokens — near-zero for instant transitions ═══ -->
  <Duration x:Key="MotionFastDuration">0:0:0.001</Duration>
  <Duration x:Key="MotionMedDuration">0:0:0.001</Duration>
  <Duration x:Key="MotionSlowDuration">0:0:0.001</Duration>

  <CubicEase x:Key="StandardEase" EasingMode="EaseOut" />
  <QuadraticEase x:Key="SoftEase" EasingMode="EaseOut" />

  <sys:Double x:Key="MotionFast">0</sys:Double>
  <sys:Double x:Key="MotionMed">0</sys:Double>
  <sys:Double x:Key="MotionSlow">0</sys:Double>
</ResourceDictionary>
