<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
  <!--
    LibreSpot Desktop design tokens.
    Dark-first, warm graphite surfaces with a confident Spotify-green accent.
    Layered backgrounds (0 = lowest, 3 = highest elevation) provide depth
    without relying on hard drop shadows, which read poorly on dark canvases.

    Token shape:
      Color / Brush  → semantic surfaces, text, accents
      CornerRadius   → Xs (2), Sm (6), Md (8), Lg (10), Xl (12), Badge (8)
      Thickness      → 4-based spacing scale (SpaceXs..SpaceXxl)
      Motion         → Fast (90ms) / Med (150ms) / Slow (220ms), all cubic-out
  -->

  <!-- ═══ Typography ═══ -->
  <FontFamily x:Key="HeadingFont">Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI</FontFamily>
  <FontFamily x:Key="BodyFont">Segoe UI Variable Text, Segoe UI</FontFamily>
  <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas</FontFamily>

  <!-- ═══ Surfaces (darkest → lightest) ═══ -->
  <Color x:Key="CanvasColor">#050A0F</Color>
  <Color x:Key="CanvasShadeColor">#071018</Color>
  <Color x:Key="Surface1Color">#0A151E</Color>
  <Color x:Key="Surface2Color">#0D1B25</Color>
  <Color x:Key="Surface3Color">#122632</Color>
  <Color x:Key="SurfaceRaisedColor">#193443</Color>
  <Color x:Key="RailColor">#07111A</Color>
  <Color x:Key="HeroStartColor">#102938</Color>
  <Color x:Key="HeroEndColor">#08131C</Color>

  <!-- ═══ Strokes ═══ -->
  <Color x:Key="StrokeColor">#294351</Color>
  <Color x:Key="StrokeSoftColor">#19303D</Color>
  <Color x:Key="StrokeStrongColor">#456576</Color>

  <!-- ═══ Text ═══ -->
  <Color x:Key="TextColor">#F3F7F6</Color>
  <Color x:Key="TextMutedColor">#B9C4C7</Color>
  <!-- Subtle tier: dimmest readable text. Calibrated to clear WCAG AA (≥4.5:1)
       on every surface tier up to SurfaceRaised, while staying a full step
       below MutedText so the caption hierarchy reads clearly. -->
  <Color x:Key="TextSubtleColor">#8D9AA0</Color>
  <Color x:Key="TextOnAccentColor">#06120B</Color>

  <!-- ═══ Brand / accent — Spotify-green, calibrated for dark canvas ═══ -->
  <Color x:Key="AccentColor">#50C878</Color>
  <Color x:Key="AccentHoverColor">#6DE391</Color>
  <Color x:Key="AccentDeepColor">#2B9E55</Color>
  <Color x:Key="AccentSoftColor">#122B1C</Color>
  <Color x:Key="AccentMistColor">#3650C878</Color>
  <Color x:Key="AccentRingColor">#B850C878</Color>

  <!-- ═══ Semantic intent ═══ -->
  <Color x:Key="DangerColor">#E5484D</Color>
  <!-- Body/caption-safe danger text. Clears WCAG AA on every raised surface;
       keep the deeper DangerColor for borders, glyph strokes, and fills. -->
  <Color x:Key="DangerTextColor">#FF7A7F</Color>
  <Color x:Key="DangerDeepColor">#C9343A</Color>
  <Color x:Key="DangerSoftColor">#261414</Color>
  <!-- Fill + text-on-fill pairs for destructive/caution surfaces (buttons, snackbars).
       Dark text on the saturated fills clears WCAG AA (≥4.5:1); TextBrush on DangerColor
       is only 3.43:1, so never put TextBrush on a Danger fill. -->
  <Color x:Key="DangerFillColor">#E5484D</Color>
  <Color x:Key="TextOnDangerColor">#07110C</Color>
  <Color x:Key="WarningFillColor">#F5A524</Color>
  <Color x:Key="TextOnWarningColor">#07110C</Color>
  <Color x:Key="WarningColor">#F5A524</Color>
  <Color x:Key="WarningSoftColor">#241A0D</Color>
  <Color x:Key="WarningRingColor">#66F5A524</Color>
  <Color x:Key="SuccessColor">#1DB954</Color>
  <Color x:Key="SuccessSoftColor">#132419</Color>
  <Color x:Key="InfoColor">#4DB8FF</Color>

  <!-- ═══ Overlays / scrim ═══ -->
  <Color x:Key="OverlayColor">#C2060A08</Color>
  <Color x:Key="ScrimColor">#66000000</Color>
  <Color x:Key="SheenColor">#0AFFFFFF</Color>

  <!-- ═══ Brushes ═══ -->
  <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}" />
  <!-- Transparent variant used only when Mica is successfully applied via DWM.
       Win11 22621+ composites the backdrop under transparent window surfaces. -->
  <SolidColorBrush x:Key="MicaCanvasBrush" Color="Transparent" />
  <SolidColorBrush x:Key="RailBrush" Color="{StaticResource RailColor}" />
  <SolidColorBrush x:Key="HeroStartBrush" Color="{StaticResource HeroStartColor}" />
  <SolidColorBrush x:Key="HeroEndBrush" Color="{StaticResource HeroEndColor}" />

  <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource Surface1Color}" />
  <SolidColorBrush x:Key="PanelStrongBrush" Color="{StaticResource Surface2Color}" />
  <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1Color}" />
  <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}" />
  <SolidColorBrush x:Key="Surface3Brush" Color="{StaticResource Surface3Color}" />
  <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />
  <SolidColorBrush x:Key="CanvasShadeBrush" Color="{StaticResource CanvasShadeColor}" />

  <!-- Premium shell layers: a restrained top-left glow, a quieter rail fade,
       and a barely lifted card face. All three flatten in high-contrast mode. -->
  <RadialGradientBrush x:Key="WorkspaceBackdropBrush"
                       GradientOrigin="0.12,0.02"
                       Center="0.12,0.02"
                       RadiusX="1.08"
                       RadiusY="0.92">
    <GradientStop Color="#1E24506A" Offset="0" />
    <GradientStop Color="{DynamicResource CanvasShadeColor}" Offset="0.36" />
    <GradientStop Color="{DynamicResource CanvasColor}" Offset="0.78" />
  </RadialGradientBrush>

  <LinearGradientBrush x:Key="RailPanelBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{DynamicResource RailColor}" Offset="0" />
    <GradientStop Color="{DynamicResource CanvasShadeColor}" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="SurfaceCardBrush" StartPoint="0,0" EndPoint="0.9,1">
    <GradientStop Color="{DynamicResource Surface2Color}" Offset="0" />
    <GradientStop Color="{DynamicResource Surface1Color}" Offset="1" />
  </LinearGradientBrush>

  <SolidColorBrush x:Key="StrokeBrush" Color="{StaticResource StrokeColor}" />
  <SolidColorBrush x:Key="StrokeSoftBrush" Color="{StaticResource StrokeSoftColor}" />
  <SolidColorBrush x:Key="StrokeStrongBrush" Color="{StaticResource StrokeStrongColor}" />

  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
  <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource TextMutedColor}" />
  <SolidColorBrush x:Key="SubtleTextBrush" Color="{StaticResource TextSubtleColor}" />
  <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}" />

  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
  <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
  <SolidColorBrush x:Key="AccentDeepBrush" Color="{StaticResource AccentDeepColor}" />
  <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
  <SolidColorBrush x:Key="AccentMistBrush" Color="{StaticResource AccentMistColor}" />
  <SolidColorBrush x:Key="AccentRingBrush" Color="{StaticResource AccentRingColor}" />

  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
  <SolidColorBrush x:Key="DangerTextBrush" Color="{StaticResource DangerTextColor}" />
  <SolidColorBrush x:Key="DangerDeepBrush" Color="{StaticResource DangerDeepColor}" />
  <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoftColor}" />
  <SolidColorBrush x:Key="DangerFillBrush" Color="{StaticResource DangerFillColor}" />
  <SolidColorBrush x:Key="TextOnDangerBrush" Color="{StaticResource TextOnDangerColor}" />
  <SolidColorBrush x:Key="WarningFillBrush" Color="{StaticResource WarningFillColor}" />
  <SolidColorBrush x:Key="TextOnWarningBrush" Color="{StaticResource TextOnWarningColor}" />
  <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
  <SolidColorBrush x:Key="WarningSoftBrush" Color="{StaticResource WarningSoftColor}" />
  <SolidColorBrush x:Key="WarningRingBrush" Color="{StaticResource WarningRingColor}" />
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
  <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource SuccessSoftColor}" />
  <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

  <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}" />
  <SolidColorBrush x:Key="ScrimBrush" Color="{StaticResource ScrimColor}" />
  <SolidColorBrush x:Key="SheenBrush" Color="{StaticResource SheenColor}" />

  <Color x:Key="TerminalBgColor">#050807</Color>
  <Color x:Key="TerminalFgColor">#D9E6DE</Color>
  <SolidColorBrush x:Key="TerminalBgBrush" Color="{StaticResource TerminalBgColor}" />
  <SolidColorBrush x:Key="TerminalFgBrush" Color="{StaticResource TerminalFgColor}" />

  <!-- ═══ Radius rhythm ═══ -->
  <CornerRadius x:Key="RadiusXs">2</CornerRadius>
  <CornerRadius x:Key="RadiusSm">6</CornerRadius>
  <CornerRadius x:Key="RadiusMd">8</CornerRadius>
  <CornerRadius x:Key="RadiusLg">10</CornerRadius>
  <CornerRadius x:Key="RadiusXl">12</CornerRadius>
  <CornerRadius x:Key="RadiusBadge">8</CornerRadius>

  <!-- ═══ Spacing (4-based) ═══ -->
  <Thickness x:Key="SpaceXs">4</Thickness>
  <Thickness x:Key="SpaceSm">8</Thickness>
  <Thickness x:Key="SpaceMd">12</Thickness>
  <Thickness x:Key="SpaceLg">16</Thickness>
  <Thickness x:Key="SpaceXl">24</Thickness>
  <Thickness x:Key="SpaceXxl">32</Thickness>

  <!-- Soft radial highlight used behind rail logo and top hero edge -->
  <RadialGradientBrush x:Key="RailGlowBrush"
                       GradientOrigin="0.5,0.25"
                       Center="0.5,0.25"
                       RadiusX="0.95"
                       RadiusY="0.65">
    <GradientStop Color="#331DB954" Offset="0" />
    <GradientStop Color="#00070A09" Offset="1" />
  </RadialGradientBrush>

  <LinearGradientBrush x:Key="SurfaceSheenBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#18FFFFFF" Offset="0" />
    <GradientStop Color="#00FFFFFF" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{DynamicResource AccentHoverColor}" Offset="0" />
    <GradientStop Color="{DynamicResource AccentDeepColor}" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="HeroPanelBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{DynamicResource HeroStartColor}" Offset="0" />
    <GradientStop Color="{DynamicResource Surface2Color}" Offset="0.58" />
    <GradientStop Color="{DynamicResource HeroEndColor}" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="HeroRingBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{DynamicResource AccentHoverColor}" Offset="0" />
    <GradientStop Color="{DynamicResource AccentColor}" Offset="0.62" />
    <GradientStop Color="{DynamicResource AccentDeepColor}" Offset="1" />
  </LinearGradientBrush>

  <!-- Shimmer sweep used on progress bars during indeterminate runs -->
  <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0.5" EndPoint="1,0.5">
    <GradientStop Color="#001ED760" Offset="0.0" />
    <GradientStop Color="#661ED760" Offset="0.5" />
    <GradientStop Color="#001ED760" Offset="1.0" />
  </LinearGradientBrush>

  <!-- ═══ Interactive overlays ═══ -->
  <SolidColorBrush x:Key="GhostButtonBgBrush" Color="#0AFFFFFF" />
  <SolidColorBrush x:Key="GhostButtonBorderBrush" Color="#182F3F37" />
  <SolidColorBrush x:Key="GhostHoverTintBrush" Color="#18FFFFFF" />
  <SolidColorBrush x:Key="DangerHoverTintBrush" Color="#30FFFFFF" />
  <SolidColorBrush x:Key="PressTintBrush" Color="#33000000" />
  <SolidColorBrush x:Key="PressTintLightBrush" Color="#16000000" />

  <!-- ═══ Elevation ═══ -->
  <DropShadowEffect x:Key="CardShadow"
                    BlurRadius="42"
                    ShadowDepth="0"
                    Direction="270"
                    Opacity="0.48"
                    Color="#05070A" />

  <DropShadowEffect x:Key="OverlayShadow"
                    BlurRadius="72"
                    ShadowDepth="0"
                    Direction="270"
                    Opacity="0.75"
                    Color="#02030A" />

  <DropShadowEffect x:Key="AccentGlow"
                    BlurRadius="22"
                    ShadowDepth="0"
                    Opacity="0.45"
                    Color="#1DB954" />

  <DropShadowEffect x:Key="TabSelectedGlow"
                    BlurRadius="18"
                    ShadowDepth="0"
                    Opacity="0.35"
                    Color="#1DB954" />

  <!-- ═══ Motion tokens ═══ -->
  <Duration x:Key="MotionFastDuration">0:0:0.090</Duration>
  <Duration x:Key="MotionMedDuration">0:0:0.150</Duration>
  <Duration x:Key="MotionSlowDuration">0:0:0.220</Duration>
  <Duration x:Key="IndeterminateSweepDuration">0:0:1.600</Duration>

  <!-- Expressive but restrained ease-out (no overshoot) -->
  <CubicEase x:Key="StandardEase" EasingMode="EaseOut" />
  <QuadraticEase x:Key="SoftEase" EasingMode="EaseOut" />

  <!-- Legacy numeric aliases retained for compatibility -->
  <sys:Double x:Key="MotionFast">90</sys:Double>
  <sys:Double x:Key="MotionMed">150</sys:Double>
  <sys:Double x:Key="MotionSlow">220</sys:Double>
</ResourceDictionary>
